@page "/"
@page "/clients"
@using RynthRemote.AcStatus
@inject IAcStatusClient Status
@inject SettingsStore SettingsSvc
@inject IJSRuntime JS
@inject IHdVideoController HdController
@implements IAsyncDisposable

<PageTitle>RynthRemote</PageTitle>

<style>
    .ac-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(250px,1fr)); gap:.75rem; }
    .ac-card { border:1px solid var(--border); border-radius:10px; padding:.7rem .8rem; background:var(--surface); }
    .ac-card.bad { border-color:var(--red); }
    /* Fleet roll-up + collapsible glance-rows (redesign Phase 1) */
    .ac-roll { display:flex; flex-wrap:wrap; gap:.4rem; align-items:center; margin-bottom:.6rem; }
    .ac-chip { font-size:.78rem; padding:.35rem .7rem; border-radius:var(--r-pill); border:1px solid var(--border); background:var(--surface-2); color:var(--text-2); cursor:pointer; min-height:38px; display:inline-flex; align-items:center; gap:.35rem; }
    .ac-chip.on { border-color:var(--accent); color:var(--text); background:var(--surface-3); }
    .ac-chip .ac-chip-n { font-weight:700; font-variant-numeric:tabular-nums; color:var(--text); }
    .ac-chip.attn .ac-chip-n { color:var(--state-bad); }
    .ac-gemdot { width:10px; height:10px; border-radius:3px; flex:none; }
    .ac-roll-meta { font-size:.7rem; color:var(--muted); margin-left:auto; }
    .ac-rowhead { display:flex; align-items:center; gap:.6rem; cursor:pointer; min-height:40px; }
    .ac-gem { width:20px; height:20px; border-radius:5px; flex:none; border:1px solid rgba(255,255,255,.16); box-shadow:inset 0 -3px 6px rgba(0,0,0,.35); }
    .ac-rowmain { flex:1; min-width:0; }
    .ac-rowsub { font-size:.72rem; color:var(--muted); text-transform:capitalize; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .ac-rowkpi { font-weight:700; font-variant-numeric:tabular-nums; color:var(--accent); font-size:1rem; white-space:nowrap; }
    .ac-rowkpi .ac-rowkpil { font-weight:400; font-size:.7rem; color:var(--muted); margin-left:.1rem; }
    .ac-rowstale { font-size:.7rem; white-space:nowrap; }
    .ac-rowchev { color:var(--muted); font-size:.95rem; width:1rem; text-align:center; flex:none; }
    /* Drill-in deck (redesign Phase 2b): full-screen focus view of one client + pinned control bar */
    .ac-deck { position:fixed; inset:0; z-index:900; display:flex; flex-direction:column; background:var(--bg); }
    .ac-deck-head { display:flex; align-items:center; gap:.5rem; padding:max(env(safe-area-inset-top,0px),47px) .7rem .5rem; border-bottom:1px solid var(--border); background:var(--surface); }
    .ac-deck-back { background:none; border:none; color:var(--accent-bright); font-size:.85rem; cursor:pointer; min-height:40px; padding:0 .2rem; white-space:nowrap; }
    .ac-deck-name { font-weight:700; flex:1; min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .ac-deck-pos { font-size:.72rem; color:var(--muted); font-variant-numeric:tabular-nums; }
    .ac-deck-nav { background:var(--surface-2); border:1px solid var(--border); color:var(--text); border-radius:var(--r-sm); min-width:42px; min-height:42px; cursor:pointer; font-size:1.1rem; }
    .ac-deck-body { flex:1; overflow-y:auto; -webkit-overflow-scrolling:touch; padding:0; }
    .ac-pane { padding:.7rem .8rem; }
    /* KPI strip + sub-tabs: non-scrolling siblings between the deck head and the scroll body. */
    .ac-kpi { display:grid; grid-template-columns:repeat(4,1fr); gap:.4rem; padding:.45rem .8rem; border-bottom:1px solid var(--border); background:var(--surface); }
    .ac-kpi-c { text-align:center; min-width:0; }
    .ac-kpi-v { font-weight:700; font-variant-numeric:tabular-nums; font-size:1.05rem; line-height:1.1; }
    .ac-kpi-v.warn { color:var(--amber); }
    .ac-kpi-l { font-size:.66rem; color:var(--muted); text-transform:uppercase; letter-spacing:.03em; }
    .ac-subnav { display:flex; gap:.25rem; padding:.4rem .6rem; border-bottom:1px solid var(--border); background:var(--surface); }
    .ac-subtab { flex:1 1 0; min-height:40px; border:1px solid var(--border); background:var(--surface-2); color:var(--text); border-radius:var(--r-sm); font-size:.8rem; cursor:pointer; }
    .ac-subtab.on { background:var(--accent); color:var(--accent-ink); border-color:transparent; font-weight:700; }
    .ac-deck-bar { display:flex; flex-wrap:wrap; gap:.3rem; align-items:stretch; padding:.4rem .6rem calc(.4rem + max(env(safe-area-inset-bottom,0px),10px)); border-top:1px solid var(--border); background:var(--surface); }
    .ac-deck-bar .ac-pill { font-size:.76rem; padding:.4rem .4rem; min-height:42px; flex:1 1 0; min-width:0; }
    .ac-deck-bar .ac-macro { flex:0 0 auto; padding:.4rem .7rem; }
    .ac-head { display:flex; align-items:center; justify-content:space-between; gap:.5rem; }
    .ac-name { font-weight:700; }
    .ac-sub { color:var(--muted); font-size:.78rem; }
    .ac-badge { font-size:.7rem; font-weight:700; text-transform:uppercase; letter-spacing:.04em; padding:.15rem .45rem; border-radius:999px; color:#0b1120; }
    .ac-bar { height:12px; border-radius:6px; background:var(--surface-2); overflow:hidden; margin:.15rem 0; }
    .ac-bar > span { display:block; height:100%; }
    /* Gemstone vitals — faceted sheen rides on top of the inline base hue; per-gem glow via explicit class (no animation: deck re-renders each ~1s poll). */
    .ac-bar.gem { height:16px; border-radius:9px; background:linear-gradient(180deg,#0a0d14,#141a26); border:1px solid rgba(255,255,255,.06); box-shadow:inset 0 1px 3px rgba(0,0,0,.6); }
    .ac-bar.gem > span { border-radius:8px; background-image:linear-gradient(180deg,rgba(255,255,255,.5),rgba(255,255,255,.08) 22%,rgba(0,0,0,.25)); background-blend-mode:screen; }
    .ac-bar.gem-ruby > span     { box-shadow:0 0 8px rgba(239,68,68,.6); }
    .ac-bar.gem-jade > span     { box-shadow:0 0 8px rgba(34,197,94,.55); }
    .ac-bar.gem-sapphire > span { box-shadow:0 0 8px rgba(59,130,246,.6); }
    .ac-vlabel { display:flex; justify-content:space-between; font-size:.7rem; color:var(--muted); }
    .ac-doing { margin:.5rem 0 .25rem; font-size:.85rem; }
    .ac-stream-bar { margin:.35rem 0 .25rem; }
    .ac-stream { margin:.25rem 0 .45rem; border:1px solid var(--border); border-radius:8px; overflow:hidden; background:#000; aspect-ratio:16/10; }
    .ac-stream img, .ac-stream video { width:100%; height:100%; object-fit:contain; display:block; background:#000; }
    .ac-hd-ph { width:100%; height:100%; display:flex; align-items:center; justify-content:center; color:#5b6b86; font-size:.8rem; text-align:center; padding:.6rem; }
    .ac-stream.armed { box-shadow:0 0 0 2px var(--accent); }
    .ac-stream.armed img { cursor:crosshair; }
    .ac-stream-min { background:var(--surface-2); }
    .ac-stream-min .ac-hd-ph { color:var(--state-warn); }
    .ac-qsel { display:flex; gap:.3rem; align-items:center; flex-wrap:wrap; margin:.2rem 0 .6rem; padding:.4rem .5rem; background:var(--surface); border:1px solid var(--border); border-radius:8px; }
    .ac-qsel .lbl { font-size:.72rem; color:var(--muted); }
    .ac-stats { display:grid; grid-template-columns:repeat(auto-fit,minmax(56px,1fr)); gap:.3rem; margin:.4rem 0 .25rem; }
    .ac-stat { background:var(--surface-2); border-radius:6px; padding:.25rem .2rem; text-align:center; }
    .ac-stat .sv { font-weight:700; font-size:.9rem; font-variant-numeric:tabular-nums; line-height:1.1; }
    .ac-stat .sv.warn { color:var(--amber); }
    .ac-stat .sl { font-size:.72rem; color:var(--muted); text-transform:uppercase; letter-spacing:.03em; }
    .ac-foot { display:flex; flex-wrap:wrap; gap:.5rem .9rem; font-size:.72rem; color:var(--muted); margin-top:.4rem; }
    .ac-issue { font-size:.72rem; color:var(--amber); margin-top:.35rem; word-break:break-word; }
    .ac-warn { color:var(--amber); }
    .ac-ctrl { display:flex; flex-wrap:wrap; gap:.3rem; margin-top:.45rem; align-items:center; }
    .ac-pill { font-size:.8rem; padding:.45rem .8rem; border-radius:var(--r-pill); border:1px solid var(--border); background:var(--surface-2); color:inherit; cursor:pointer; min-height:40px; display:inline-flex; align-items:center; justify-content:center; gap:.25rem; }
    .ac-pill:disabled { opacity:.5; cursor:default; }
    .ac-pill.on { background:#34d399; color:#06281c; border-color:transparent; font-weight:700; }
    .ac-pill.applying { box-shadow:0 0 0 2px var(--accent); animation:ac-applying 1.1s ease-in-out infinite; }
    @@keyframes ac-applying { 0%,100%{opacity:1} 50%{opacity:.55} }
    /* Close-confirm countdown modal */
    .ac-cc-back { position:fixed; inset:0; background:rgba(0,0,0,.62); display:flex; align-items:center; justify-content:center; z-index:1100; padding:.8rem; }
    .ac-cc { width:100%; max-width:20rem; background:var(--surface); border:1px solid var(--red); border-radius:var(--r-md); padding:1rem; text-align:center; box-shadow:var(--e2); }
    .ac-cc-title { font-weight:700; margin-bottom:.3rem; }
    .ac-cc-ring { font-size:2.2rem; font-weight:700; font-variant-numeric:tabular-nums; color:var(--red); margin:.4rem 0; animation:ac-cc-pulse 1s ease-in-out infinite; }
    .ac-cc-row { display:flex; gap:.5rem; margin-top:.7rem; }
    @@keyframes ac-cc-pulse { 0%,100%{transform:scale(1)} 50%{transform:scale(1.12)} }
    @@media (prefers-reduced-motion:reduce) { .ac-cc-ring { animation:none; } }
    @@media (prefers-reduced-motion:reduce) { .ac-pill.applying { animation:none; } }
    .ac-pill.ac-macro.on { background:#f87171; color:#3a0b0b; }
    .ac-sel { font-size:.8rem; padding:.45rem .5rem; border-radius:var(--r-sm); border:1px solid var(--border); background:var(--surface-2); color:inherit; flex:1 1 30%; min-width:0; min-height:var(--tap); }
    .ac-cmd-msg { font-size:.7rem; color:var(--muted); margin-top:.25rem; }
    .ac-pill.ac-danger { background:#f87171; color:#3a0b0b; border-color:transparent; font-weight:700; }
    .ac-gear { margin-top:.4rem; }
    .ac-gear-h { font-size:.74rem; background:none; border:none; color:var(--muted); cursor:pointer; padding:.4rem .2rem; min-height:40px; display:inline-flex; align-items:center; gap:.3rem; }
    .ac-gear-list { display:flex; flex-direction:column; gap:.12rem; margin-top:.2rem; }
    .ac-inv-grp { font-size:.72rem; font-weight:700; margin:.4rem 0 .1rem; opacity:.9; }
    .ac-inv-cap { color:var(--muted); font-weight:400; margin-left:.3rem; }
    .ac-ico { width:1.4rem; height:1.4rem; vertical-align:middle; margin-right:.3rem; image-rendering:pixelated; border-radius:3px; }
    .ac-inv-open .ac-inv-hint { color:var(--muted); font-size:.7rem; font-weight:400; margin-left:.4rem; }

    /* ── AC parchment inventory popup ── */
    .ac-invm-backdrop { position:fixed; inset:0; background:rgba(0,0,0,.62); display:flex; align-items:center; justify-content:center; z-index:1000; padding:.6rem; }
    .ac-invm { width:100%; max-width:30rem; max-height:90vh; display:flex; flex-direction:column; overflow:hidden;
               background:linear-gradient(180deg,#e8d6ad,#d8c08c); color:#2a1d0e;
               border:3px solid #5a3d1c; border-radius:8px; box-shadow:0 0 0 2px #2a1d0e,0 12px 40px rgba(0,0,0,.7);
               font-family:Georgia,'Times New Roman',serif; }
    .ac-invm-bar { display:flex; align-items:center; justify-content:space-between; padding:.45rem .6rem;
                   background:linear-gradient(180deg,#6b4a24,#4a3014); color:#f1e3c0; border-bottom:2px solid #2a1d0e; }
    .ac-invm-title { font-weight:700; font-size:.95rem; letter-spacing:.02em; }
    .ac-invm-x { background:none; border:none; color:#f1e3c0; font-size:1.15rem; cursor:pointer; padding:0 .3rem; line-height:1; }
    .ac-invm-tabs { display:flex; flex-wrap:wrap; gap:.25rem; padding:.4rem .5rem 0; }
    .ac-invm-tab { background:#c4a772; color:#3a2810; border:2px solid #5a3d1c; border-bottom:none; border-radius:5px 5px 0 0;
                   padding:.2rem .5rem; font-size:.72rem; cursor:pointer; font-family:inherit; }
    .ac-invm-tab.on { background:#ecdcb4; font-weight:700; }
    .ac-invm-tn { color:var(--pch-ink-2); margin-left:.3rem; font-size:.72rem; }
    .ac-invm-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(3rem,1fr)); gap:.3rem; padding:.5rem;
                    overflow-y:auto; background:#ecdcb4; border-top:2px solid #5a3d1c; }
    .ac-invm-cell { position:relative; aspect-ratio:1; display:flex; align-items:center; justify-content:center; padding:.15rem;
                    background:linear-gradient(160deg,#cbb486,#b89c68); border:2px solid #8a6a3a; border-radius:4px; cursor:pointer;
                    box-shadow:inset 0 0 4px rgba(90,61,28,.4); }
    .ac-invm-cell.sel { border-color:#e8c060; box-shadow:0 0 0 2px #e8c060,inset 0 0 4px rgba(90,61,28,.4); }
    .ac-invm-ico { max-width:100%; max-height:100%; image-rendering:pixelated; }
    .ac-invm-q { color:var(--pch-ink-2); font-size:1.2rem; }
    .ac-invm-stack { position:absolute; right:1px; bottom:0; font-size:.72rem; font-weight:700; color:#fff; font-family:Arial,sans-serif;
                     background:rgba(42,29,14,.85); border-radius:3px; padding:0 .2rem; }
    .ac-invm-empty { grid-column:1/-1; text-align:center; color:var(--pch-ink-2); padding:1rem; }
    .ac-invm-exam { margin:.1rem .5rem .5rem; padding:.4rem .5rem; background:#f3e8cb; border:2px solid #8a6a3a; border-radius:5px; }
    .ac-invm-exam-h { font-weight:700; font-size:.85rem; color:#3a2810; border-bottom:1px solid #c4a772; padding-bottom:.2rem; margin-bottom:.25rem; }
    .ac-invm-s { color:var(--pch-ink-2); font-size:.74rem; font-style:italic; }
    .ac-invm-msg { padding:1.2rem; text-align:center; color:#5a3d1c; background:#ecdcb4; }
    .ac-invm-foot { padding:.4rem .5rem; display:flex; justify-content:flex-end; background:linear-gradient(180deg,#d8c08c,#c4a772); border-top:2px solid #5a3d1c; }
    /* make the shared appraisal view legible on parchment */
    .ac-invm-exam .ac-appr { color:#2a1d0e; border-left-color:#8a6a3a; }
    .ac-invm-exam .ac-appr .amono, .ac-invm-exam .ac-appr .adesc { color:#5a3d1c; }
    .ac-invm-exam .ac-appr .rb { color:#9a5a10; }
    .ac-invm-exam .ac-appr .aspells .sp { background:#d8c08c; color:#2a1d0e; }
    .ac-gear-row { display:flex; justify-content:space-between; gap:.5rem; font-size:.72rem; }
    .ac-gear-row { cursor:pointer; }
    .ac-gear-row .gn { overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .ac-gear-row .gi { color:var(--muted); font-family:ui-monospace,monospace; user-select:all; white-space:nowrap; }
    .ac-ctabs { display:flex; flex-wrap:wrap; gap:.25rem; margin:.2rem 0 .1rem; }
    .ac-ctab { font-size:.78rem; padding:.35rem .55rem; }
    .ac-chat-log { max-height:200px; overflow-y:auto; background:var(--bg); border:1px solid var(--border); border-radius:6px; padding:.35rem .45rem; display:flex; flex-direction:column; gap:.1rem; margin:.2rem 0; }
    .ac-chat-line { font-size:.74rem; line-height:1.25; word-break:break-word; }
    .ac-chat-send { display:flex; gap:.3rem; }
    .ac-chat-input { flex:1; min-width:0; background:var(--surface-2); border:1px solid var(--border); border-radius:var(--r-sm); color:inherit; padding:.5rem .55rem; font-size:.9rem; min-height:var(--tap); }
    .ac-dpad { display:grid; grid-template-columns:repeat(3,1fr); grid-template-rows:repeat(3,1fr); gap:.35rem; max-width:230px; margin:.3rem auto .1rem; touch-action:none; }
    .ac-dbtn { position:relative; display:flex; align-items:center; justify-content:center; aspect-ratio:1; font-size:1.5rem; line-height:1; background:var(--surface-2); border:1px solid var(--border); border-radius:10px; color:inherit; user-select:none; -webkit-user-select:none; -webkit-tap-highlight-color:transparent; cursor:pointer; transition:transform .07s ease, box-shadow .07s ease; }
    /* held/firing = depressed key + bright inner ring + outward gold halo (one-shot transform/shadow, no animation) */
    .ac-dbtn:active, .ac-dbtn.held {
        background:radial-gradient(circle at 50% 38%, var(--accent-bright), var(--accent) 60%, var(--accent-deep));
        border-color:var(--accent-bright); color:var(--accent-ink); transform:scale(.94); z-index:1;
        box-shadow:inset 0 2px 5px rgba(0,0,0,.45), inset 0 0 0 2px var(--accent-bright), 0 0 0 3px rgba(217,164,65,.45), 0 0 14px 2px rgba(217,164,65,.55);
    }
    @@media (prefers-reduced-motion:reduce) { .ac-dbtn:active, .ac-dbtn.held { transform:none; } }
    .ac-dbtn.stop { font-size:1.05rem; color:var(--amber); }
    .ac-dnote { font-size:.7rem; color:var(--muted); text-align:center; }
    .ac-appr { font-size:.7rem; margin:.15rem 0 .35rem .6rem; padding-left:.5rem; border-left:2px solid var(--border); display:flex; flex-direction:column; gap:.15rem; }
    .ac-appr b { font-weight:700; }
    .ac-appr .rb { color:var(--amber); margin-left:.4rem; }
    .ac-appr .amono { color:var(--muted); display:flex; flex-wrap:wrap; gap:.5rem; }
    .ac-appr .aspells { display:flex; flex-wrap:wrap; gap:.25rem; }
    .ac-appr .aspells .sp { background:var(--surface-2); border-radius:4px; padding:.05rem .35rem; }
    .ac-appr .adesc { color:var(--muted); font-style:italic; }
    /* View tabs (Clients / Archive) */
    .ac-tabs { display:flex; gap:.4rem; margin:.2rem 0 .7rem; }
    .ac-tab { font-size:.9rem; padding:.5rem 1.1rem; border-radius:var(--r-pill); border:1px solid var(--border); background:var(--surface-2); color:inherit; cursor:pointer; min-height:var(--tap); display:inline-flex; align-items:center; justify-content:center; }
    .ac-tab.on { background:var(--accent); color:#0b1220; border-color:transparent; font-weight:700; }
    /* Archive (run history) */
    .ac-runs { display:flex; flex-direction:column; gap:.4rem; }
    .ac-run { border:1px solid var(--border); border-radius:10px; background:var(--surface); overflow:hidden; }
    .ac-run.live { border-color:#34d399; }
    .ac-run-h { width:100%; display:flex; align-items:center; gap:.6rem; padding:.6rem .7rem; background:none; border:none; color:inherit; cursor:pointer; text-align:left; }
    .ac-run-h .rh-exp { color:var(--muted); font-size:.8rem; }
    .ac-run-h .rh-main { display:flex; flex-direction:column; min-width:0; flex:1; }
    .ac-run-h .rh-who { font-weight:700; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .ac-run-h .rh-when { font-size:.72rem; color:var(--muted); }
    .ac-run-h .rh-kpi { display:flex; flex-direction:column; align-items:flex-end; line-height:1.1; }
    .ac-run-h .rh-k { font-weight:700; font-variant-numeric:tabular-nums; }
    .ac-run-h .rh-kl { font-size:.72rem; color:var(--muted); text-transform:uppercase; letter-spacing:.03em; }
    .ac-run-h .rh-dur { font-size:.78rem; color:var(--muted); min-width:3.4rem; text-align:right; font-variant-numeric:tabular-nums; }
    .ac-run .ac-stats { padding:0 .7rem; margin-top:.1rem; }
    .ac-run .ac-foot { padding:.15rem .7rem .6rem; }
    /* Archive = parchment ledger (read-only "game talking"); scoped under .ac-runs.parch so the shared
       .ac-stat/.ac-foot/.ac-badge used in the dark deck are never globally repainted. */
    .ac-runs.parch { font-family:Georgia,'Times New Roman',serif; }
    .ac-runs.parch .ac-run { background:linear-gradient(180deg,var(--pch-bg-1),var(--pch-bg-2)); border:2px solid var(--pch-edge); color:var(--pch-ink); box-shadow:0 1px 0 #2a1d0e, 0 4px 14px rgba(0,0,0,.35); }
    .ac-runs.parch .ac-run.live { border-color:var(--accent-deep); box-shadow:0 0 0 1px var(--pch-gold), 0 4px 14px rgba(0,0,0,.4); }
    .ac-runs.parch .ac-run-h { background:linear-gradient(180deg,#6b4a24,#4a3014); color:#f1e3c0; border-bottom:2px solid var(--pch-edge); }
    .ac-runs.parch .rh-exp, .ac-runs.parch .rh-when, .ac-runs.parch .rh-kl, .ac-runs.parch .rh-dur { color:#d8c08c; }
    .ac-runs.parch .rh-who { color:#f1e3c0; }
    .ac-runs.parch .rh-k { color:var(--pch-gold); }
    .ac-runs.parch .ac-run.live .ac-badge { background:var(--accent)!important; color:var(--accent-ink); }
    .ac-runs.parch .ac-stats { background:var(--pch-panel); border-top:2px solid var(--pch-edge); padding-top:.4rem; }
    .ac-runs.parch .ac-stat { background:#e6d3a4; border:1px solid var(--pch-rule); }
    .ac-runs.parch .ac-stat .sv { color:var(--pch-ink); }
    .ac-runs.parch .ac-stat .sv.warn { color:var(--pch-accent); }
    .ac-runs.parch .ac-stat .sl { color:var(--pch-ink-2); }
    .ac-runs.parch .ac-foot { background:var(--pch-panel); color:var(--pch-ink-2); border-top:1px dashed var(--pch-rule); font-style:italic; }
    /* First-run welcome (dark operator chrome — this is the REMOTE talking, not a game surface) */
    .rr-welcome { border-color:var(--accent-deep); box-shadow:var(--e1); }
    .rr-w-h { display:flex; gap:.6rem; align-items:center; margin-bottom:.5rem; }
    .rr-w-logo { font-size:1.8rem; color:var(--accent); line-height:1; }
    .rr-w-sub { margin:.1rem 0 0; color:var(--muted); font-size:.8rem; }
    .rr-w-explain { font-size:.86rem; color:var(--text-2); margin:.2rem 0 .6rem; line-height:1.45; }
    .rr-w-steps { display:flex; flex-direction:column; gap:.25rem; margin:.2rem 0 .7rem; }
    .rr-w-steps span { font-size:.8rem; color:var(--text-2); border-left:2px solid var(--accent-deep); padding-left:.5rem; }
    .rr-w-help { display:block; font-size:.74rem; color:var(--muted); margin-top:.1rem; line-height:1.35; }
    .rr-w-opt { font-size:.7rem; color:var(--muted); font-weight:400; }
    /* Healthy→critical alert banner stack (in-app, newest on top) */
    .ac-alerts { display:flex; flex-direction:column; gap:.35rem; margin-bottom:.6rem; }
    .ac-alert { display:flex; align-items:center; gap:.5rem; padding:.5rem .6rem; min-height:44px; border:1px solid var(--border); border-radius:var(--r-sm); background:var(--surface-2); cursor:pointer; }
    .ac-alert.crit { border-color:var(--red); }
    .ac-alert-rail { width:4px; align-self:stretch; border-radius:2px; flex:none; }
    .ac-alert-txt { flex:1; min-width:0; font-size:.84rem; }
    .ac-alert-x { background:none; border:none; color:var(--muted); font-size:1.2rem; min-width:40px; min-height:40px; cursor:pointer; }
    /* Council (fleet-wide batch control) */
    .ac-council-scope { font-size:.82rem; color:var(--text-2); margin:.2rem 0 .55rem; display:flex; align-items:center; gap:.4rem; flex-wrap:wrap; }
    .ac-council-acts { display:grid; grid-template-columns:repeat(2,1fr); gap:.4rem; margin-bottom:.5rem; }
    .ac-council-acts .ac-pill { min-height:44px; }
    .ac-link { background:none; border:none; color:var(--accent-bright); cursor:pointer; font-size:.8rem; padding:0 .2rem; text-decoration:underline; }
    /* Leaderboard (ranked live fleet) */
    .ac-lb { margin-bottom:.6rem; }
    .ac-lb-row { display:flex; align-items:center; gap:.5rem; min-height:44px; }
    .ac-lb-rank { font-variant-numeric:tabular-nums; color:var(--muted); width:1.6rem; text-align:right; flex:none; }
    .ac-lb-name { flex:1; min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .ac-lb-val { font-weight:700; font-variant-numeric:tabular-nums; color:var(--accent); white-space:nowrap; min-width:3rem; text-align:right; }
    .ac-lb-row.stale { opacity:.7; }
    .ac-lb-row.stale .ac-lb-val { color:var(--amber); }
    /* Dungeon-map viewer */
    .ac-map-bar { display:flex; gap:.3rem; align-items:center; margin:.35rem 0; }
    .ac-map-vp { position:relative; overflow:hidden; height:62vh; touch-action:none; background:var(--surface-2); border:1px solid var(--border); border-radius:var(--r-md); }
    .ac-map-wrap { position:relative; width:100%; will-change:transform; }
    .ac-map-img { position:absolute; display:block; image-rendering:pixelated; -webkit-user-drag:none; user-select:none; }
    .ac-map-ovl { position:absolute; inset:0; width:100%; height:100%; pointer-events:none; }
    /* Advanced settings form */
    .ac-set-bar { display:flex; gap:.3rem; align-items:center; margin:.3rem 0; }
    .ac-set-grp { margin:.15rem 0; }
    .ac-set-row { display:flex; align-items:center; gap:.5rem; min-height:40px; padding:.1rem 0 .1rem .6rem; }
    .ac-set-lbl { flex:1; min-width:0; font-size:.8rem; }
    .ac-set-lbl.applying { color:var(--accent-bright); }
    .ac-set-step { display:flex; align-items:center; gap:.35rem; flex:none; }
    .ac-set-step .ac-pill { min-width:40px; }
    .ac-set-val { min-width:3.4rem; text-align:center; font-variant-numeric:tabular-nums; font-weight:700; }
    .ac-set-val.applying { color:var(--accent-bright); }
    .ac-set-seg { display:flex; gap:.2rem; flex-wrap:wrap; justify-content:flex-end; flex:none; }
</style>

<div class="card-head">
    <h1>RynthRemote</h1>
    <div class="flex" style="gap:.5rem">
        <button class="btn-r ghost sm" @onclick="() => _showControls = !_showControls">@(_showControls ? "Hide controls" : "Controls")</button>
        <button class="btn-r ghost sm" @onclick="ToggleConfig">@(_showConfig ? "Close" : "Connection")</button>
        <button class="btn-r ghost sm" @onclick="Refresh" disabled="@string.IsNullOrWhiteSpace(_url)">Refresh</button>
    </div>
</div>

<div class="ac-tabs">
    <button class="ac-tab @(_view == "clients" ? "on" : "")" @onclick="@(() => SwitchView("clients"))">Clients</button>
    <button class="ac-tab @(_view == "council" ? "on" : "")" @onclick="@(() => SwitchView("council"))">Council</button>
    <button class="ac-tab @(_view == "maps" ? "on" : "")" @onclick="@(() => SwitchView("maps"))">Maps</button>
    <button class="ac-tab @(_view == "archive" ? "on" : "")" @onclick="@(() => SwitchView("archive"))">Archive</button>
</div>

@if (_showConfig || string.IsNullOrWhiteSpace(_url))
{
    bool firstRun = string.IsNullOrWhiteSpace(_url);   // FIRST statement = C# code context (no @)
    <div class="card-r mb @(firstRun ? "rr-welcome" : "")">
        @if (firstRun)
        {
            <div class="rr-w-h"><span class="rr-w-logo">⚜</span><div><h3 style="margin:0">Welcome to RynthRemote</h3><p class="rr-w-sub">Your pocket console for the fleet.</p></div></div>
            <p class="rr-w-explain">
                RynthRemote watches and controls your Asheron's Call clients through the
                <b>RynthCore StatusAgent</b> running on your PC — over <b>Tailscale</b> (anywhere) or your <b>home Wi-Fi</b>.
                Point it at the agent once and your characters, vitals, and controls show up here.
            </p>
            <div class="rr-w-steps">
                <span>1 · Start RynthCore + the StatusAgent on your PC</span>
                <span>2 · Copy the status URL it prints on launch</span>
                <span>3 · Save — you're connected</span>
            </div>
        }
        else
        {
            <h3 style="margin-top:0">RynthCore StatusAgent</h3>
            <p class="muted" style="font-size:.82rem;margin-top:0">
                URL of your StatusAgent's pull endpoint, e.g. <code>http://your-pc:8740/status</code>
                (over Tailscale/LAN). Leave the token blank unless you set <code>ServeToken</code>.
            </p>
        }
        <div class="field">
            <label>Status URL</label>
            <input @bind="_urlEdit" placeholder="http://your-pc:8740/status" inputmode="url" autocapitalize="off" autocorrect="off" spellcheck="false" />
            @if (firstRun) { <span class="rr-w-help">The StatusAgent prints this on launch. Over Tailscale use the PC's tailnet name, e.g. <code>http://workshop:8740/status</code>.</span> }
        </div>
        <div class="field">
            <label>Token <span class="rr-w-opt">(optional)</span></label>
            <input @bind="_tokenEdit" placeholder="bearer token, if any" autocapitalize="off" autocorrect="off" spellcheck="false" />
            @if (firstRun) { <span class="rr-w-help">Leave blank unless you set <code>ServeToken</code> on the agent.</span> }
        </div>
        <div class="flex" style="gap:.5rem;margin-top:.5rem">
            <button class="btn-r" @onclick="SaveConfig">@(firstRun ? "Connect" : "Save")</button>
            @if (_savedConfig) { <span class="badge-r green">saved</span> }
        </div>
    </div>
}

@{ var live = _alerts.Where(a => (DateTime.UtcNow - a.AtUtc).TotalSeconds < 60).ToList(); }
@if (live.Count > 0)
{
    <div class="ac-alerts">
        @foreach (var a in live)
        {
            var col = a.Sev == "crit" ? "#f87171" : "#fbbf24";
            <div class="ac-alert @a.Sev" @key="a.Id" @onclick="@(() => JumpToAlert(a))">
                <span class="ac-alert-rail" style="background:@col"></span>
                <span class="ac-alert-txt">@a.Text</span>
                <button class="ac-alert-x" @onclick:stopPropagation="true" @onclick="@(() => DismissAlert(a.Id))">×</button>
            </div>
        }
    </div>
}

@if (_view == "council")
{
    if (string.IsNullOrWhiteSpace(_url))
    {
        <div class="card-r"><p class="muted" style="margin-top:0">Set your StatusAgent URL (Connection) to control the fleet.</p></div>
    }
    else if (_result?.Payload is null)
    {
        <p class="loading">Connecting to @_url …</p>
    }
    else
    {
        var all = _result.Payload.Clients;
        var set = CouncilSet();
        var setPids = set.Select(c => c.Pid).ToList();
        <div class="ac-roll">
            <button class="ac-chip @(_fleetFilter == "" ? "on" : "")" @onclick="@(() => SetFleetFilter(""))"><span class="ac-chip-n">@all.Count</span> all</button>
            @foreach (var g in FleetGroups(all))
            {
                string k = g.Key;
                <button class="ac-chip @(g.Attn ? "attn" : "") @(_fleetFilter == k ? "on" : "")" @onclick="@(() => SetFleetFilter(k))"><span class="ac-gemdot" style="background:@StateColor(k)"></span><span class="ac-chip-n">@g.Count</span> @k</button>
            }
        </div>
        <div class="ac-council-scope">
            Acting on <b>@set.Count</b> of @all.Count @(set.Count == 1 ? "client" : "clients")@(string.IsNullOrEmpty(_fleetFilter) ? "" : " · " + _fleetFilter)
            @if (!string.IsNullOrEmpty(_fleetFilter)) { <button class="ac-link" @onclick="@(() => SetFleetFilter(""))">whole fleet</button> }
            <button class="ac-link" style="margin-left:auto" @onclick="ToggleAlertSound" title="beep on a critical alert (death / wedge) while the app is open">🔔 alert sound @(_alertSound ? "on" : "off")</button>
        </div>

        <div class="ac-council-acts">
            <button class="ac-pill" disabled="@(set.Count == 0)" @onclick="@(() => BatchCommandAsync("macro", "true", setPids))">▶ Start all</button>
            <button class="ac-pill" disabled="@(set.Count == 0)" @onclick="@(() => OpenFleetConfirm("macro", "false", $"Stop all {set.Count} clients?", "Pauses botting on the whole scoped fleet."))">■ Stop all</button>
            <button class="ac-pill" disabled="@(set.Count == 0)" @onclick="@(() => BatchCommandAsync("forceRebuff", "true", setPids))">✦ Rebuff all</button>
            <button class="ac-pill" disabled="@(set.Count == 0)" @onclick="@(() => BatchCommandAsync("clearBusy", "true", setPids))">clear busy all</button>
            <button class="ac-pill" disabled="@(set.Count == 0)" @onclick="@(() => BatchCommandAsync("cancelRebuff", "true", setPids))">cancel rebuff all</button>
            <button class="ac-pill" disabled="@(set.Count == 0)" @onclick="@(() => BatchCommandAsync("hideUi", "true", setPids))">Hide UI all</button>
            <button class="ac-pill" disabled="@(set.Count == 0)" @onclick="@(() => BatchCommandAsync("hideUi", "false", setPids))">Show UI all</button>
            <button class="ac-pill ac-danger" disabled="@(set.Count == 0)" @onclick="@(() => OpenFleetConfirm("closeClient", "true", $"Close all {set.Count} clients?", "This shuts down the game clients."))">Close all</button>
        </div>
        @if (!string.IsNullOrEmpty(_batchMsg)) { <div class="ac-cmd-msg">@_batchMsg</div> }

        <div class="ac-lb">
            <button class="ac-gear-h" @onclick="@(() => _lbExpanded = !_lbExpanded)">
                @(_lbExpanded ? "▾" : "▸") Leaderboard
            </button>
            @if (_lbExpanded)
            {
                var ranked = set.OrderBy(c => (StaleKill(c) || !c.Healthy) ? 1 : 0).ThenByDescending(c => LbValue(c, _lbMetric)).ThenBy(c => c.DisplayName).ToList();
                double max = ranked.Count > 0 ? Math.Max(1, ranked.Max(c => LbValue(c, _lbMetric))) : 1;
                <div class="ac-ctabs">
                    @foreach (var m in LbMetrics)
                    {
                        string mk = m.Key;
                        <button class="ac-pill ac-ctab @(_lbMetric == mk ? "on" : "")" @onclick="@(() => SetLbMetric(mk))">@m.Label</button>
                    }
                </div>
                @for (int i = 0; i < ranked.Count; i++)
                {
                    var c = ranked[i];
                    bool stalled = StaleKill(c) || !c.Healthy;
                    double val = LbValue(c, _lbMetric);
                    <div class="ac-lb-row @(stalled ? "stale" : "")">
                        <span class="ac-lb-rank">@(i + 1)</span>
                        <span class="ac-gem" style="background:@StateColor(c.State)"></span>
                        <span class="ac-lb-name">@c.DisplayName</span>
                        <span class="ac-bar" style="flex:0 0 64px"><span style="width:@((int)Math.Clamp(val / max * 100, 0, 100))%;background:var(--accent)"></span></span>
                        <span class="ac-lb-val">@FmtRate(val)</span>
                    </div>
                }
                @if (ranked.Count == 0) { <div class="ac-sub">no clients in scope</div> }
            }
        </div>

        <div class="ac-grid">
            @foreach (var c in set.OrderByDescending(c => !c.Healthy).ThenBy(c => c.Character))
            {
                <div class="ac-card @(c.Healthy ? "" : "bad")" @key="c.Pid">
                    <div class="ac-rowhead" @onclick="@(() => OpenDeck(c.Pid))">
                        <span class="ac-gem" style="background:@StateColor(c.State)" title="@c.State"></span>
                        <div class="ac-rowmain">
                            <div class="ac-name">@c.DisplayName</div>
                            <div class="ac-rowsub">@c.State@(string.IsNullOrWhiteSpace(c.BotAction) ? "" : " · " + c.BotAction)</div>
                        </div>
                        <span class="ac-pill ac-macro @(EffOn(c.Pid, "macro", c.MacroRunning) ? "on" : "") @(IsApplying(c.Pid, "macro") ? "applying" : "")">@(EffOn(c.Pid, "macro", c.MacroRunning) ? "■" : "▶")</span>
                        <span class="ac-rowchev">›</span>
                    </div>
                </div>
            }
            @if (set.Count == 0) { <div class="card-r">No clients in this scope.</div> }
        </div>
    }
}
else if (_view == "archive")
{
    <div class="card-head" style="margin-bottom:.4rem">
        <span class="ac-sub">@(_runs is { Count: > 0 } ? $"{_runs.Count} run(s)" : "Run history")</span>
        <button class="btn-r ghost sm" @onclick="LoadRunsAsync" disabled="@(string.IsNullOrWhiteSpace(_url) || _runsLoading)">@(_runsLoading ? "…" : "Refresh")</button>
    </div>

    @if (string.IsNullOrWhiteSpace(_url))
    {
        <div class="card-r"><p class="muted" style="margin-top:0">Set your StatusAgent URL (Connection) to see past runs.</p></div>
    }
    else if (_runsError is not null)
    {
        <div class="card-r"><p class="ac-warn" style="margin-top:0">&#9888; @_runsError</p></div>
    }
    else if (_runs is null)
    {
        <p class="loading">Loading run history…</p>
    }
    else if (_runs.Count == 0)
    {
        <div class="card-r"><p class="muted" style="margin-top:0">No runs recorded yet. Sessions show up here as clients finish — and the current run appears live while a client is botting.</p></div>
    }
    else
    {
        <div class="ac-runs parch">
            @foreach (var r in _runs)
            {
                bool open = _expandedRuns.Contains(r.Key);
                <div class="ac-run @(r.Ongoing ? "live" : "")" @key="r.Key">
                    <button class="ac-run-h" @onclick="@(() => ToggleRun(r.Key))">
                        <span class="rh-exp">@(open ? "▾" : "▸")</span>
                        <span class="rh-main">
                            <span class="rh-who">@r.DisplayName</span>
                            <span class="rh-when">@RunWhen(r)</span>
                        </span>
                        <span class="rh-kpi">
                            <span class="rh-k">@r.Kills</span>
                            <span class="rh-kl">kills</span>
                        </span>
                        <span class="rh-dur">@Dur(r.DurationSec)</span>
                        @if (r.Ongoing) { <span class="ac-badge" style="background:#34d399">live</span> }
                    </button>
                    @if (open)
                    {
                        <div class="ac-stats">
                            @Stat("Kills", r.Kills.ToString())
                            @Stat("Kills/hr", FmtRate(r.KillsPerHour))
                            @Stat("XP", FmtRate(r.Xp))
                            @Stat("XP/hr", FmtRate(r.XpPerHour))
                            @Stat("Deaths", r.Deaths.ToString(), r.Deaths > 0)
                            @if (r.LuminancePerHour > 0) { @Stat("Lum/hr", FmtRate(r.LuminancePerHour)) }
                            @if (r.VitaePct > 0) { @Stat("Vitae", r.VitaePct.ToString("F0") + "%", true) }
                            @Stat("Duration", Dur(r.DurationSec))
                        </div>
                        <div class="ac-foot">
                            @if (!string.IsNullOrWhiteSpace(r.Server)) { <span>@r.Server</span> }
                            @if (!string.IsNullOrWhiteSpace(r.Area)) { <span>area @r.Area</span> }
                            <span>started @RunDateLong(r.StartUtc)</span>
                            <span>@(r.Ongoing ? "in progress" : "ended " + RunDateLong(r.EndUtc))</span>
                        </div>
                    }
                </div>
            }
        </div>
    }
}
else if (_view == "maps")
{
    bool noUrl = string.IsNullOrWhiteSpace(_url);
    <div class="card-head" style="margin-bottom:.4rem">
        <span class="ac-sub">@(_maps is { Maps.Count: > 0 } ? $"{_maps.Maps.Select(m => m.LandblockId).Distinct().Count()} dungeon(s)" : "Dungeon maps")</span>
        <button class="btn-r ghost sm" @onclick="LoadMapsAsync" disabled="@(noUrl || _mapsLoading)">@(_mapsLoading ? "…" : "Refresh")</button>
    </div>
    @if (noUrl)
    {
        <div class="card-r"><p class="muted" style="margin-top:0">Set your StatusAgent URL (Connection) to view dungeon maps.</p></div>
    }
    else if (_mapsLoading && _maps is null)
    {
        <p class="loading">Loading maps…</p>
    }
    else if (_mapsError is not null)
    {
        <div class="card-r"><p class="ac-warn" style="margin-top:0">&#9888; @_mapsError</p></div>
    }
    else if (_maps is null || _maps.Maps.Count == 0)
    {
        <div class="card-r"><p class="muted" style="margin-top:0">No dungeon maps baked yet. Walk a bot into a dungeon in-game to bake its floor plan, then tap Refresh.</p></div>
    }
    else
    {
        var dungeons = _maps.Maps.Select(m => m.LandblockId).Distinct().OrderBy(x => x).ToList();
        var floors = _maps.Maps.Where(m => m.LandblockId == _selDungeon).OrderBy(m => m.Layer).ToList();
        var selFloors = floors.Where(f => _selLayers.Contains(f.Layer)).OrderBy(f => f.Layer).ToList();
        var indoorClients = _result?.Payload?.Clients?.Where(cc => cc.Indoor && cc.LandblockId != 0).ToList() ?? new();
        <div class="ac-roll">
            @foreach (var lb in dungeons)
            {
                uint d = lb;
                string nm = _maps.Maps.First(m => m.LandblockId == d).Name ?? "";
                <button class="ac-chip @(_selDungeon == d ? "on" : "")" @onclick="@(() => SelectDungeon(d))">@(string.IsNullOrWhiteSpace(nm) ? $"Dungeon {d & 0xFFFF:X4}" : nm)</button>
            }
        </div>
        @if (floors.Count > 1)
        {
            <div class="ac-ctabs">
                <span class="ac-sub" style="align-self:center;margin-right:.2rem">floors:</span>
                @foreach (var f in floors)
                {
                    int ly = f.Layer;
                    <button class="ac-pill ac-ctab @(_selLayers.Contains(ly) ? "on" : "")" @onclick="@(() => ToggleLayer(ly))">@f.FloorLabel</button>
                }
            </div>
        }
        @if (indoorClients.Count > 0)
        {
            <div class="ac-ctabs">
                <span class="ac-sub" style="align-self:center;margin-right:.2rem">live dot:</span>
                @foreach (var ic in indoorClients)
                {
                    int icp = ic.Pid;
                    <button class="ac-pill ac-ctab @(_mapClientPid == icp ? "on" : "")" @onclick="@(() => SelectMapClient(icp))">@ic.DisplayName</button>
                }
            </div>
        }
        @if (selFloors.Count > 0)
        {
            int uXMin = selFloors.Min(f => f.XMin);
            int uYMax = selFloors.Max(f => f.YMin + f.H);
            int uW = Math.Max(1, selFloors.Max(f => f.XMin + f.W) - uXMin);
            int uH = Math.Max(1, uYMax - selFloors.Min(f => f.YMin));
            var mc = MapClient();
            (double X, double Y)? dot = (mc != null && selFloors.Any(f => MapDot(mc, f) != null))
                ? (mc.Wx / 0.5 - uXMin, (uYMax - 1) - mc.Wy / 0.5) : null;
            <div class="ac-map-bar">
                <button class="ac-pill" @onclick="@(() => MapZoom(1.25))" aria-label="zoom in">＋</button>
                <button class="ac-pill" @onclick="@(() => MapZoom(0.8))" aria-label="zoom out">－</button>
                <button class="ac-pill" @onclick="MapReset">Reset</button>
                <span class="lbl" style="margin-left:auto">@selFloors.Count floor@(selFloors.Count == 1 ? "" : "s")</span>
            </div>
            <div class="ac-map-vp"
                 @onpointerdown="MapPointerDown" @onpointermove="MapPointerMove"
                 @onpointerup="MapPointerUp" @onpointercancel="MapPointerUp" @onpointerleave="MapPointerUp">
                <div class="ac-map-wrap" style="aspect-ratio:@uW / @uH;transform:translate(@(_panX.ToString(CI))px,@(_panY.ToString(CI))px) scale(@_zoom.ToString(CI));transform-origin:0 0">
                    @foreach (var f in selFloors)
                    {
                        double fl = (f.XMin - uXMin) * 100.0 / uW;
                        double ft = (uYMax - (f.YMin + f.H)) * 100.0 / uH;
                        double fw = f.W * 100.0 / uW;
                        double fh = f.H * 100.0 / uH;
                        string op = (selFloors.Count == 1 ? 1.0 : 0.6).ToString(CI);
                        <img class="ac-map-img" alt="@f.FloorLabel"
                             style="left:@fl.ToString(CI)%;top:@ft.ToString(CI)%;width:@fw.ToString(CI)%;height:@fh.ToString(CI)%;opacity:@op"
                             src="@AcStatusClient.BuildMapUrl(_url, f.LandblockId, f.Layer, _token)" />
                    }
                    @if (dot is { } pt)
                    {
                        <svg class="ac-map-ovl" viewBox="0 0 @uW @uH" preserveAspectRatio="none">
                            <circle cx="@pt.X.ToString(CI)" cy="@pt.Y.ToString(CI)" r="3" fill="#33ff66" stroke="#0b1220" stroke-width="1"></circle>
                        </svg>
                    }
                </div>
            </div>
            <div class="ac-sub" style="margin-top:.35rem">Tap floors to overlay or hide them. Drag to pan · ＋/－ to zoom.</div>
        }
        else
        {
            <div class="card-r"><p class="muted" style="margin-top:0">Tap a floor above to show it.</p></div>
        }
    }
}
else if (string.IsNullOrWhiteSpace(_url))
{
    <div class="card-r"><p class="muted">Set your StatusAgent URL above to see your AC clients.</p></div>
}
else if (_result is null)
{
    <p class="loading">Connecting to @_url …</p>
}
else if (!_result.Ok)
{
    <div class="card-r">
        <p class="ac-warn" style="margin-top:0">&#9888; @_result.Error</p>
        <p class="ac-sub">@_url — retrying every few seconds.</p>
    </div>
}
else
{
    var clients = _result.Payload!.Clients;

    if (clients.Count == 0)
    {
        <div class="card-r mb">No clients running.</div>
    }
    else
    {
        <div class="ac-roll">
            <button class="ac-chip @(_fleetFilter == "" ? "on" : "")" @onclick="@(() => SetFleetFilter(""))"><span class="ac-chip-n">@clients.Count</span> all</button>
            @foreach (var g in FleetGroups(clients))
            {
                string k = g.Key;
                <button class="ac-chip @(g.Attn ? "attn" : "") @(_fleetFilter == k ? "on" : "")" @onclick="@(() => SetFleetFilter(k))"><span class="ac-gemdot" style="background:@StateColor(k)"></span><span class="ac-chip-n">@g.Count</span> @k</button>
            }
            <span class="ac-roll-meta">@_result.Payload.Host · @Ago(_result.Payload.GeneratedAtUtc)</span>
        </div>
    }

    <div class="ac-grid">
        @foreach (var c in FilterClients(clients).OrderByDescending(c => !c.Healthy).ThenBy(c => c.Character))
        {
            <div class="ac-card @(c.Healthy ? "" : "bad")" @key="c.Pid">
                <div class="ac-rowhead" @onclick="@(() => OpenDeck(c.Pid))">
                    <span class="ac-gem" style="background:@StateColor(c.State)" title="@c.State"></span>
                    <div class="ac-rowmain">
                        <div class="ac-name">@c.DisplayName</div>
                        <div class="ac-rowsub">@c.State@(c.IsMinimized ? " · minimized" : "")@(string.IsNullOrWhiteSpace(c.Server) ? "" : " · " + c.Server)</div>
                    </div>
                    @if (c.KillsPerHour > 0) { <span class="ac-rowkpi">@FmtRate(c.KillsPerHour)<span class="ac-rowkpil">k/hr</span></span> }
                    @if (c.AgeSec >= 12) { <span class="ac-warn ac-rowstale">stale</span> }
                    <span class="ac-rowchev">›</span>
                </div>

                @if (_deckPid == c.Pid)
                {
                    var kHb = string.Equals(c.Source, "heartbeat-log", StringComparison.OrdinalIgnoreCase);
                    <div class="ac-deck">
                        <div class="ac-deck-head">
                            <button class="ac-deck-back" @onclick="CloseDeck">‹ Fleet</button>
                            <span class="ac-gem" style="background:@StateColor(c.State)" title="@c.State"></span>
                            <span class="ac-deck-name">@c.DisplayName</span>
                            <span class="ac-deck-pos">@DeckPos(c.Pid)</span>
                            <button class="ac-deck-nav" @onclick="@(() => DeckStep(-1))" aria-label="previous client">‹</button>
                            <button class="ac-deck-nav" @onclick="@(() => DeckStep(1))" aria-label="next client">›</button>
                        </div>
                        <div class="ac-kpi">
                            <div class="ac-kpi-c"><div class="ac-kpi-v">@(kHb ? "—" : FmtRate(c.KillsPerHour))</div><div class="ac-kpi-l">kills/hr</div></div>
                            <div class="ac-kpi-c"><div class="ac-kpi-v">@(kHb ? "—" : FmtRate(c.XpPerHour))</div><div class="ac-kpi-l">xp/hr</div></div>
                            <div class="ac-kpi-c"><div class="ac-kpi-v @(!kHb && c.DeathsSession > 0 ? "warn" : "")">@(kHb ? "—" : c.DeathsSession.ToString())</div><div class="ac-kpi-l">deaths</div></div>
                            <div class="ac-kpi-c"><div class="ac-kpi-v @(c.FreeSlots >= 0 && c.FreeSlots <= 2 ? "warn" : "")">@(c.FreeSlots < 0 ? "—" : c.FreeSlots.ToString())</div><div class="ac-kpi-l">slots</div></div>
                        </div>
                        <div class="ac-subnav">
                            @foreach (var st in DeckTabs)
                            {
                                string t = st;
                                <button class="ac-subtab @(_deckTab == t ? "on" : "")" @onclick="@(() => SetDeckTab(t))">@t</button>
                            }
                        </div>
                        <div class="ac-deck-body">
                            @if (_deckTab == "Status")
                            {
                                <div class="ac-pane">
                                    @if (c.Player is { } v && v.MaxHp > 0)
                                    {
                                        @Bar("HP", v.Hp, v.MaxHp, "#ef4444", "ruby")
                                        @Bar("Stam", v.St, v.MaxSt, "#22c55e", "jade")
                                        @Bar("Mana", v.Mn, v.MaxMn, "#3b82f6", "sapphire")
                                    }
                                    <div class="ac-doing">
                                        @if (!string.IsNullOrWhiteSpace(c.BotAction)) { <span>@c.BotAction</span> }
                                        else if (!string.IsNullOrWhiteSpace(c.CurrentState)) { <span>@c.CurrentState</span> }
                                        else { <span class="ac-sub">@(c.InWorld ? "In world" : "Not in world")</span> }
                                        @if (!string.IsNullOrWhiteSpace(c.Target)) { <span class="ac-sub"> → @c.Target</span> }
                                    </div>
                                    @if (!kHb)
                                    {
                                        <div class="ac-stats">
                                            @Stat("kills/hr", c.KillsPerHour.ToString("F0"))
                                            @Stat("kills", c.SessionKills.ToString())
                                            @Stat("last kill", Since(c.SecsSinceLastKill), StaleKill(c))
                                            @Stat("xp/hr", FmtRate(c.XpPerHour))
                                            @Stat("xp ses", FmtRate(c.XpSession))
                                            @if (c.LuminancePerHour > 0) { @Stat("lum/hr", FmtRate(c.LuminancePerHour)) }
                                            @Stat("vitae", c.VitaePct > 0 ? $"{c.VitaePct:F0}%" : "0")
                                            @Stat("deaths", c.DeathsSession > 0 ? $"{c.DeathsSession}/{c.Deaths}" : c.Deaths.ToString())
                                            @if (c.BurdenPct > 0) { @Stat("burden", $"{c.BurdenPct:F0}%", c.BurdenPct >= 100) }
                                            @if (c.FreeSlots >= 0) { @Stat("slots", c.FreeSlots.ToString(), c.FreeSlots <= 2) }
                                            @if (c.ScarabsByType is { Count: > 0 })
                                            {
                                                @foreach (var s in c.ScarabsByType)
                                                {
                                                    @Stat(s.ShortLabel, s.Count.ToString(), s.Count <= 50)
                                                }
                                            }
                                            else if (c.Scarabs >= 0) { @Stat("scarabs", c.Scarabs.ToString(), c.Scarabs <= 50) }
                                            @if (c.Tapers >= 0) { @Stat("tapers", c.Tapers.ToString(), c.Tapers <= 50) }
                                            @if (!string.IsNullOrWhiteSpace(c.Area)) { @Stat("area", c.Area!) }
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(c.LastIssue))
                                        {
                                            <div class="ac-issue" title="most recent engine warning/error">
                                                &#9888; @c.LastIssue@(c.LastIssueAgeSec >= 0 ? $" ({Since((int)c.LastIssueAgeSec)} ago)" : "")
                                            </div>
                                        }
                                        @if (c.Equipment is { Count: > 0 })
                                        {
                                            <div class="ac-gear">
                                                <button class="ac-gear-h" @onclick="@(() => ToggleGear(c.Pid))">
                                                    @(_showGear.Contains(c.Pid) ? "▾" : "▸") Gear (@c.Equipment.Count)
                                                </button>
                                                @if (_showGear.Contains(c.Pid))
                                                {
                                                    <div class="ac-gear-list">
                                                        @foreach (var it in c.Equipment)
                                                        {
                                                            <div>
                                                                <div class="ac-gear-row" @onclick="@(() => ToggleItem(it.Id))" title="tap for appraisal">
                                                                    <span class="gn">@(it.HasAppraisal ? (_showItem.Contains(it.Id) ? "▾ " : "▸ ") : "")@it.Name</span>
                                                                    <span class="gi">@it.HexId</span>
                                                                </div>
                                                                @if (_showItem.Contains(it.Id) && it.HasAppraisal)
                                                                {
                                                                    <AcAppraisal Item="it" />
                                                                }
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        }
                                        <div class="ac-gear">
                                            <button class="ac-gear-h ac-inv-open" @onclick="@(() => OpenInvModal(c.Pid))">
                                                🎒 Inventory@(InvCountLabel(c.Pid)) <span class="ac-inv-hint">tap to open ▸</span>
                                            </button>
                                        </div>
                                    }
                                    <div class="ac-foot">
                                        <span class="@(c.InWorld && c.Fps == 0 ? "ac-warn" : "")">@c.Fps fps</span>
                                        <span class="@(c.MacroRunning && c.PluginTicksPerSec == 0 ? "ac-warn" : "")">@c.PluginTicksPerSec /s</span>
                                        <span>up @Dur(c.UptimeSec)</span>
                                        @if (c.AgeSec >= 12) { <span class="ac-warn">stale @c.AgeSec.ToString("F0")s</span> }
                                        @if (kHb) { <span title="basic info only — status export off for this client">log-only</span> }
                                    </div>
                                </div>
                            }
                            else if (_deckTab == "Control")
                            {
                                <div class="ac-pane">
                                    @if (c.NavProfiles is { Count: > 0 } || c.LootProfiles is { Count: > 0 } || c.MetaProfiles is { Count: > 0 })
                                    {
                                        <div class="ac-ctrl">
                                            @if (c.NavProfiles is { Count: > 0 })
                                            {
                                                <select class="ac-sel" title="nav profile" @onchange="@(e => CmdProfile(c, "navProfile", e))">
                                                    @for (int i = 0; i < c.NavProfiles.Count; i++)
                                                    { <option value="@i" selected="@(i == c.SelectedNavIdx)">@Trunc(c.NavProfiles[i])</option> }
                                                </select>
                                            }
                                            @if (c.LootProfiles is { Count: > 0 })
                                            {
                                                <select class="ac-sel" title="loot profile" @onchange="@(e => CmdProfile(c, "lootProfile", e))">
                                                    @for (int i = 0; i < c.LootProfiles.Count; i++)
                                                    { <option value="@i" selected="@(i == c.SelectedLootIdx)">@Trunc(c.LootProfiles[i])</option> }
                                                </select>
                                            }
                                            @if (c.MetaProfiles is { Count: > 0 })
                                            {
                                                <select class="ac-sel" title="meta profile" @onchange="@(e => CmdProfile(c, "metaProfile", e))">
                                                    @for (int i = 0; i < c.MetaProfiles.Count; i++)
                                                    { <option value="@i" selected="@(i == c.SelectedMetaIdx)">@Trunc(c.MetaProfiles[i])</option> }
                                                </select>
                                            }
                                        </div>
                                    }
                                    <div class="ac-ctrl">
                                        <button class="ac-pill" @onclick="@(() => SendCommand(c, "clearBusy", "true"))">clear busy</button>
                                        <button class="ac-pill" @onclick="@(() => SendCommand(c, "forceRebuff", "true"))">force rebuff</button>
                                        <button class="ac-pill" @onclick="@(() => SendCommand(c, "cancelRebuff", "true"))">cancel</button>
                                        <button class="ac-pill @(EffOn(c.Pid, "hideUi", c.UiHidden) ? "on" : "") @(IsApplying(c.Pid, "hideUi") ? "applying" : "")" @onclick="@(() => SendCommand(c, "hideUi", EffOn(c.Pid, "hideUi", c.UiHidden) ? "false" : "true"))">@(EffOn(c.Pid, "hideUi", c.UiHidden) ? "Show UI" : "Hide UI")</button>
                                        <button class="ac-pill ac-danger" @onclick="@(() => OpenCloseModal(c.Pid))">Close</button>
                                    </div>
                                    @if (_cmdMsg.TryGetValue(c.Pid, out var cm) && !string.IsNullOrEmpty(cm))
                                    {
                                        <div class="ac-cmd-msg">@cm</div>
                                    }
                                    <div class="ac-gear">
                                        <button class="ac-gear-h ac-inv-open" @onclick="@(() => ToggleSettings(c.Pid))">
                                            ⚙ All settings <span class="ac-inv-hint">@(_settingsOpen ? "▾ close" : "▸ open")</span>
                                        </button>
                                    </div>
                                    @if (_settingsOpen && _settingsPid == c.Pid)
                                    {
                                        if (_settingsLoading && _settingsValues == null)
                                        {
                                            <p class="loading">Loading settings…</p>
                                        }
                                        else if (_settingsError != null)
                                        {
                                            <div class="card-r"><p class="ac-warn" style="margin-top:0">&#9888; @_settingsError</p></div>
                                        }
                                        else if (_settingsValues == null || _settingsValues.Count == 0)
                                        {
                                            <div class="ac-sub">No settings reported — is this client running RynthAi with status export on?</div>
                                        }
                                        else
                                        {
                                            <div class="ac-set-bar">
                                                <input class="ac-chat-input" placeholder="search settings…" value="@_settingsSearch" @oninput="@(e => _settingsSearch = e.Value?.ToString() ?? string.Empty)" />
                                                <button class="ac-pill" @onclick="@(() => LoadSettings(c.Pid, false))" title="refresh">↻</button>
                                            </div>
                                            @foreach (var g in AcSettingsSchema.Groups)
                                            {
                                                var rows = AcSettingsSchema.All.Where(d => d.Group == g && SettingsMatch(d)).ToList();
                                                if (rows.Count == 0) { continue; }
                                                bool gopen = _settingsGroupsOpen.Contains(g) || !string.IsNullOrWhiteSpace(_settingsSearch);
                                                <div class="ac-set-grp">
                                                    <button class="ac-gear-h" @onclick="@(() => ToggleSettingsGroup(g))">@(gopen ? "▾" : "▸") @g <span class="ac-sub">(@rows.Count)</span></button>
                                                    @if (gopen)
                                                    {
                                                        foreach (var d in rows)
                                                        {
                                                            <div class="ac-set-row">
                                                                <span class="ac-set-lbl @(IsSetPending(d.Key) ? "applying" : "")">@d.Label</span>
                                                                @if (d.Type == AcSettingType.Bool)
                                                                {
                                                                    <button class="ac-pill @(CurBool(d) ? "on" : "") @(IsSetPending(d.Key) ? "applying" : "")" @onclick="@(() => ToggleSetting(d))">@(CurBool(d) ? "On" : "Off")</button>
                                                                }
                                                                else if (d.Type == AcSettingType.Enum && d.Options != null)
                                                                {
                                                                    <div class="ac-set-seg">
                                                                        @for (int oi = 0; oi < d.Options.Length; oi++)
                                                                        {
                                                                            int idx = oi;
                                                                            <button class="ac-pill ac-ctab @(CurEnum(d) == idx ? "on" : "")" @onclick="@(() => SetEnum(d, idx))">@d.Options[idx]</button>
                                                                        }
                                                                    </div>
                                                                }
                                                                else if (d.Type == AcSettingType.ReadOnly)
                                                                {
                                                                    <span class="ac-sub">@CurText(d)</span>
                                                                }
                                                                else
                                                                {
                                                                    <div class="ac-set-step">
                                                                        <button class="ac-pill" @onclick="@(() => StepSetting(d, -1))">−</button>
                                                                        <span class="ac-set-val @(IsSetPending(d.Key) ? "applying" : "")">@FmtNum(d)</span>
                                                                        <button class="ac-pill" @onclick="@(() => StepSetting(d, 1))">+</button>
                                                                    </div>
                                                                }
                                                            </div>
                                                        }
                                                    }
                                                </div>
                                            }
                                        }
                                    }
                                </div>
                            }
                            else if (_deckTab == "Live")
                            {
                                <div class="ac-pane">
                                    <div class="ac-stream-bar">
                                        <button class="ac-pill @(_streaming.Contains(c.Pid) ? "on" : "")" @onclick="@(() => ToggleStream(c.Pid))">
                                            @(_streaming.Contains(c.Pid) ? "■ Stop stream" : "▶ Live view")
                                        </button>
                                        @if (_streaming.Contains(c.Pid) && !c.IsMinimized && !Presets[PresetFor(c.Pid)].Hd)
                                        {
                                            <button class="ac-pill @(_clickArmed ? "on" : "")" @onclick="@(() => _clickArmed = !_clickArmed)" title="tap the live view to click in the game">👆 @(_clickArmed ? "Tap-to-click ON" : "Tap-to-click")</button>
                                        }
                                    </div>
                                    @if (_streaming.Contains(c.Pid))
                                    {
                                        @if (c.IsMinimized)
                                        {
                                            <div class="ac-stream ac-stream-min"><div class="ac-hd-ph">⤢ @c.DisplayName is minimized on the PC — restore it to stream (it can sit behind other windows, just not minimized)</div></div>
                                        }
                                        else if (Presets[PresetFor(c.Pid)].Hd)
                                        {
                                            <div id="@HdSlotId(c.Pid)" class="ac-stream"><div class="ac-hd-ph">📺 HD live — tap to enlarge</div></div>
                                        }
                                        else
                                        {
                                            <div class="ac-stream @(_clickArmed ? "armed" : "")">
                                                <img id="@StreamImgId(c.Pid)" src="@StreamSrc(c.Pid)" alt="live view of @c.DisplayName" @onclick="@(e => StreamTap(c.Pid, e))" />
                                            </div>
                                            @if (_clickArmed)
                                            {
                                                <div class="ac-sub" style="text-align:center;margin-top:-.3rem">👆 tap the view to click in-game</div>
                                            }
                                        }
                                        <div class="ac-qsel">
                                            @for (int i = 0; i < Presets.Length; i++)
                                            {
                                                int idx = i; int pid = c.Pid;
                                                <button class="ac-pill @(PresetFor(pid) == idx ? "on" : "")" @onclick="@(() => SetPreset(pid, idx))">@Presets[idx].Label</button>
                                            }
                                            <span class="lbl" style="margin-left:auto">@DataRateText(c.Pid)</span>
                                        </div>
                                    }
                                    <div class="ac-dpad">
                                        <span></span>
                                        <div class="ac-dbtn @(Held(c.Pid, "forward"))"
                                             @onpointerdown="@(() => StartMove(c, "forward"))"
                                             @onpointerup="@(() => StopMove(c, "forward"))"
                                             @onpointerleave="@(() => StopMove(c, "forward"))"
                                             @onpointercancel="@(() => StopMove(c, "forward"))"
                                             @oncontextmenu:preventDefault>▲</div>
                                        <span></span>
                                        <div class="ac-dbtn @(Held(c.Pid, "left"))"
                                             @onpointerdown="@(() => StartMove(c, "left"))"
                                             @onpointerup="@(() => StopMove(c, "left"))"
                                             @onpointerleave="@(() => StopMove(c, "left"))"
                                             @onpointercancel="@(() => StopMove(c, "left"))"
                                             @oncontextmenu:preventDefault>◀</div>
                                        <div class="ac-dbtn stop" @onclick="@(() => HardStop(c))">■</div>
                                        <div class="ac-dbtn @(Held(c.Pid, "right"))"
                                             @onpointerdown="@(() => StartMove(c, "right"))"
                                             @onpointerup="@(() => StopMove(c, "right"))"
                                             @onpointerleave="@(() => StopMove(c, "right"))"
                                             @onpointercancel="@(() => StopMove(c, "right"))"
                                             @oncontextmenu:preventDefault>▶</div>
                                        <span></span>
                                        <div class="ac-dbtn @(Held(c.Pid, "back"))"
                                             @onpointerdown="@(() => StartMove(c, "back"))"
                                             @onpointerup="@(() => StopMove(c, "back"))"
                                             @onpointerleave="@(() => StopMove(c, "back"))"
                                             @onpointercancel="@(() => StopMove(c, "back"))"
                                             @oncontextmenu:preventDefault>▼</div>
                                        <span></span>
                                    </div>
                                    <div class="ac-dnote">hold to move · ◀▶ turn · ■ stop @(c.MacroRunning ? "· stop the macro first — nav & combat facing will fight you" : "")</div>
                                </div>
                            }
                            else
                            {
                                <div class="ac-pane">
                                    <div class="ac-ctabs">
                                        @foreach (var tab in ChatTabs)
                                        {
                                            string t = tab; int pid = c.Pid;
                                            <button class="ac-pill ac-ctab @(ChatTabFor(pid) == t ? "on" : "")" @onclick="@(() => SetChatTab(pid, t))">@t</button>
                                        }
                                    </div>
                                    <div class="ac-chat-log" id="ac-chat-log">
                                        @{
                                            var curTab = ChatTabFor(c.Pid);
                                            var lines = (c.RecentChat ?? new()).Where(l => curTab == "All" || l.Route == curTab).ToList();
                                        }
                                        @if (lines.Count > 0)
                                        {
                                            @foreach (var ln in lines)
                                            {
                                                <div class="ac-chat-line" style="color:@ln.Color">@ln.Text</div>
                                            }
                                        }
                                        else { <div class="ac-sub">@(c.RecentChat is { Count: > 0 } ? $"no {curTab} messages" : "no chat captured yet")</div> }
                                    </div>
                                    <div class="ac-chat-send">
                                        <input class="ac-chat-input" placeholder="say, or /tell /f /command…"
                                               value="@GetDraft(c.Pid)"
                                               @oninput="@(e => _chatDraft[c.Pid] = e.Value?.ToString() ?? string.Empty)"
                                               @onkeydown="@(e => ChatKeyDown(e, c))" />
                                        <button class="ac-pill" @onclick="@(() => SendChat(c))">Send</button>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="ac-deck-bar">
                            <button class="ac-pill ac-macro @(EffOn(c.Pid, "macro", c.MacroRunning) ? "on" : "") @(IsApplying(c.Pid, "macro") ? "applying" : "")" @onclick="@(() => SendCommand(c, "macro", EffOn(c.Pid, "macro", c.MacroRunning) ? "false" : "true"))">@(EffOn(c.Pid, "macro", c.MacroRunning) ? "■" : "▶")</button>
                            @foreach (var t in Toggles(c))
                            {
                                <button class="ac-pill @(EffOn(c.Pid, t.Action, t.On) ? "on" : "") @(IsApplying(c.Pid, t.Action) ? "applying" : "")" @onclick="@(() => SendCommand(c, t.Action, EffOn(c.Pid, t.Action, t.On) ? "false" : "true"))">@t.Label</button>
                            }
                            <button class="ac-pill @(_deckTab == "Control" ? "on" : "")" @onclick="@(() => SetDeckTab("Control"))">More</button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}

@* ── AC parchment inventory popup (one open at a time) ───────────────────────────────── *@
@if (_invModalPid != 0)
{
    <div class="ac-invm-backdrop" @onclick="CloseInvModal">
        <div class="ac-invm" @onclick:stopPropagation="true">
            <div class="ac-invm-bar">
                <span class="ac-invm-title">@_invModalName — Inventory</span>
                <button class="ac-invm-x" @onclick="CloseInvModal" title="close">✕</button>
            </div>
            @if (_invByPid.TryGetValue(_invModalPid, out var inv) && inv.ItemCount > 0)
            {
                <div class="ac-invm-tabs">
                    @foreach (var cont in inv.Containers)
                    {
                        uint cid = cont.Id;
                        <button class="ac-invm-tab @(_invTabId == cid ? "on" : "")" @onclick="@(() => SelectTab(cid))">
                            @cont.Name<span class="ac-invm-tn">@inv.ItemsIn(cont).Count()@(cont.Capacity > 0 ? "/" + cont.Capacity : "")</span>
                        </button>
                    }
                </div>
                var curCont = inv.Containers.FirstOrDefault(x => x.Id == _invTabId) ?? inv.Containers.FirstOrDefault();
                var cells = curCont != null ? inv.ItemsIn(curCont).ToList() : new List<AcInventoryItem>();
                <div class="ac-invm-grid">
                    @foreach (var it in cells)
                    {
                        <button class="ac-invm-cell @(_invSelItem == it.Id ? "sel" : "")" @onclick="@(() => SelectInvItem(it))" title="@it.Name">
                            @if (it.IconDid != 0 && !string.IsNullOrWhiteSpace(_url))
                            {
                                <img class="ac-invm-ico" loading="lazy" alt="" src="@AcStatusClient.BuildIconUrl(_url, it.IconDid, _token)" onerror="this.style.visibility='hidden'" />
                            }
                            else
                            {
                                <span class="ac-invm-q">?</span>
                            }
                            @if (it.StackCount > 1)
                            {
