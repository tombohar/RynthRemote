        catch (OperationCanceledException) { }
    }
    private void CancelCloseModal() { _closeCts?.Cancel(); _closeModalPid = 0; if (!_disposed) _ = InvokeAsync(StateHasChanged); }
    private async Task ConfirmCloseModal(AcClientStatus c) { _closeCts?.Cancel(); _closeModalPid = 0; await SendCommand(c, "closeClient", "true"); }

    // ── Healthy→critical alerts (in-app / foreground only; transition-only, no 1s spam) ──
    // Real "buzz my phone while the app is closed" push is NOT here: the WS/poll loops suspend when iOS
    // backgrounds us, so no detection runs; on resume the 3s rebaseline guard deliberately swallows the
    // backlog. APNs would need an Apple push cert + device-token registration + agent-side push — a separate
    // initiative that breaks this phase's no-agent-change rule. Documented as future work.
    private readonly Dictionary<int, (string State, int Deaths, bool Stale)> _prevSnap = new();
    private sealed record AlertItem(long Id, int Pid, string Kind, string Text, string Sev, DateTime AtUtc);
    private readonly List<AlertItem> _alerts = new();
    private long _alertSeq;
    private readonly Dictionary<string, DateTime> _alertCooldown = new();   // "pid:kind" -> last raised (flap guard)
    private bool _alertsNeedRebase = true;                                  // rebaseline (no fire) on the FIRST snapshot after cold-start / resume / URL-change — latency-proof
    private bool _alertSound;                                               // opt-in beep on a crit alert
    private const string AlertSoundKey = "ac.alert.sound";
    private static readonly HashSet<string> CritStates = new(StringComparer.OrdinalIgnoreCase) { "wedged", "hung", "dead" };

    // Repopulate the baseline from the current snapshot WITHOUT firing (cold start / resume / URL change).
    private void RebaseSnap(List<AcClientStatus> clients)
    {
        _prevSnap.Clear();
        foreach (var c in clients)
            if (!string.Equals(c.Source, "heartbeat-log", StringComparison.OrdinalIgnoreCase))
                _prevSnap[c.Pid] = (c.State, c.DeathsSession, StaleKill(c));
    }

    // Diff each fresh snapshot against the previous one and raise an alert ONLY on a per-pid transition.
    // Called right after ReconcilePending at both feed-landing sites (poll + WS push).
    private void ProcessAlerts(AcStatusResult r)
    {
        if (r is not { Ok: true, Payload: not null }) return;            // never touch the baseline on a failed/partial payload
        var clients = r.Payload.Clients;
        if (_alertsNeedRebase)      // first snapshot after cold-start / resume / URL-change → rebaseline silently, no backlog dump (regardless of reconnect latency)
        {
            RebaseSnap(clients);
            _alertsNeedRebase = false;
            return;
        }
        var live = new HashSet<int>();
        foreach (var c in clients)
        {
            if (string.Equals(c.Source, "heartbeat-log", StringComparison.OrdinalIgnoreCase)) continue;   // no bot fields
            live.Add(c.Pid);
            bool curStale = StaleKill(c);
            if (_prevSnap.TryGetValue(c.Pid, out var p))
            {
                if (!CritStates.Contains(p.State) && CritStates.Contains(c.State))
                    Raise(c.Pid, "down", "crit", $"{c.DisplayName} went {c.State}");
                if (c.DeathsSession > p.Deaths)
                    Raise(c.Pid, "death", "crit", $"{c.DisplayName} died (death #{c.DeathsSession})");
                if (curStale && !p.Stale)
                    Raise(c.Pid, "stall", "warn", $"{c.DisplayName} stalled — no kill in {Since(c.SecsSinceLastKill)}");
            }
            _prevSnap[c.Pid] = (c.State, c.DeathsSession, curStale);     // overwrite each tick ⇒ an ongoing wedge never re-fires
        }
        if (_prevSnap.Count > live.Count)                               // prune vanished boxes
            foreach (var k in _prevSnap.Keys.Where(k => !live.Contains(k)).ToList()) _prevSnap.Remove(k);
    }

    private void Raise(int pid, string kind, string sev, string text)
    {
        string key = pid + ":" + kind;
        if (_alertCooldown.TryGetValue(key, out var last) && (DateTime.UtcNow - last).TotalSeconds < 60) return;   // flap guard
        _alertCooldown[key] = DateTime.UtcNow;
        _alerts.Insert(0, new AlertItem(++_alertSeq, pid, kind, text, sev, DateTime.UtcNow));
        while (_alerts.Count > 5) _alerts.RemoveAt(_alerts.Count - 1);
        if (_alertSound && sev == "crit") { try { _ = JS.InvokeVoidAsync("rynthBeep"); } catch { } }
    }

    private void DismissAlert(long id) { _alerts.RemoveAll(a => a.Id == id); StateHasChanged(); }
    private void JumpToAlert(AlertItem a) { _alerts.RemoveAll(x => x.Id == a.Id); _view = "clients"; OpenDeck(a.Pid); }

    // ── Council (fleet-wide batch control) + Leaderboard + fleet-confirm state ──
    private string? _batchMsg;                          // transient "sent to N / N failed" feedback
    private string _lbMetric = "khr";                  // leaderboard metric: khr | xphr | kills
    private bool _lbExpanded = true;
    private const string LbMetricKey = "ac.lb.metric";
    private sealed record FleetConfirm(string Action, string Value, string Title, string Sub, IReadOnlyList<int> Pids);
    private FleetConfirm? _fleetConfirm;
    private int _fleetCountdown;
    private CancellationTokenSource? _fleetCts;

    // Clients in the current fleet-filter scope (reuses the P1 roll-up filter), excluding heartbeat-log
    // clients (no bot control fields). Empty filter = whole fleet.
    private List<AcClientStatus> CouncilSet()
        => (_result?.Payload?.Clients is { } cs ? FilterClients(cs) : Enumerable.Empty<AcClientStatus>())
            .Where(c => !string.Equals(c.Source, "heartbeat-log", StringComparison.OrdinalIgnoreCase))
            .ToList();

    // Fan one action out to many clients at once: concurrent POSTs + ONE settle + ONE refresh (never loop
    // the per-client SendCommand — that's N×1.2s). PostCommandAsync returns Fail (never throws) on a
    // network/agent failure, so a dead box can't break the batch; the 6s ReconcilePending timeout clears
    // any pill whose POST failed. (It DOES throw on parent-token cancellation — guarded below.)
    private async Task BatchCommandAsync(string action, string value, IReadOnlyList<int> pids)
    {
        if (pids.Count == 0) return;
        if (value is "true" or "false")                         // optimistic flip for stateful toggles the feed reconciles
        {
            var clients = _result?.Payload?.Clients;
            foreach (var pid in pids)
            {
                var c = clients?.FirstOrDefault(x => x.Pid == pid);
                if (c != null && ActualToggle(c, action) != null)
                {
                    _pending[PKey(pid, action)] = value == "true";
                    _pendingAt[PKey(pid, action)] = DateTime.UtcNow;
                }
            }
        }
        _batchMsg = "sending…";
        StateHasChanged();                                      // every affected row shimmers at once
        var ct = _cts?.Token ?? CancellationToken.None;
        AcCommandResult[] results;
        try { results = await Task.WhenAll(pids.Select(p => Status.PostCommandAsync(_url, _token, p, action, value, ct))); }
        catch (OperationCanceledException) { return; }   // page disposed / host switched mid-batch — abandon quietly
        int ok = results.Count(r => r.Ok), fail = results.Length - ok;
        _batchMsg = fail == 0 ? $"✓ sent to {ok}" : $"sent {ok}, {fail} failed";
        StateHasChanged();
        try { await Task.Delay(1200, ct); } catch { }           // ONE settle, not per-pid
        if (!_disposed) await RefreshOnceAsync(ct);             // ONE refresh → ReconcilePending clears all shimmers together
        _ = ClearBatchMsgLater();
    }

    private async Task ClearBatchMsgLater()
    {
        try { await Task.Delay(3000); } catch { }
        if (_disposed) return;
        _batchMsg = null;
        await InvokeAsync(StateHasChanged);
    }

    // Fleet confirm = a parallel countdown to the single-pid close modal (kept separate to keep blast radius
    // small). SNAPSHOTS the target pids at open time, so a filter change before confirm can't widen the set.
    private void OpenFleetConfirm(string action, string value, string title, string sub)
    {
        var pids = CouncilSet().Select(c => c.Pid).ToList();
        if (pids.Count == 0) return;
        _fleetConfirm = new(action, value, title, sub, pids);
        _fleetCountdown = 5;
        _fleetCts?.Cancel(); _fleetCts = new();
        StateHasChanged();
        _ = FleetCountdownLoop(_fleetCts.Token);
    }
    private async Task FleetCountdownLoop(CancellationToken ct)
    {
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
            while (await timer.WaitForNextTickAsync(ct))
            {
                _fleetCountdown--;
                if (_fleetCountdown <= 0) { CancelFleetConfirm(); return; }   // auto-cancel, never auto-fire
                if (!_disposed) await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }
    private void CancelFleetConfirm() { _fleetCts?.Cancel(); _fleetConfirm = null; if (!_disposed) _ = InvokeAsync(StateHasChanged); }
    private async Task ConfirmFleet()
    {
        var fc = _fleetConfirm; if (fc is null) return;
        _fleetCts?.Cancel(); _fleetConfirm = null;
        await BatchCommandAsync(fc.Action, fc.Value, fc.Pids);
    }

    // ── Leaderboard (live ranking of the scoped fleet) ──
    private static readonly (string Key, string Label)[] LbMetrics = { ("khr", "kills/hr"), ("xphr", "xp/hr"), ("kills", "kills") };
    private static double LbValue(AcClientStatus c, string m) => m switch { "xphr" => c.XpPerHour, "kills" => c.SessionKills, _ => c.KillsPerHour };
    private async Task SetLbMetric(string m)
    {
        if (_lbMetric == m) return;
        _lbMetric = m;
        try { await SettingsSvc.SetAsync(LbMetricKey, m); } catch { }
        StateHasChanged();
    }
    private async Task ToggleAlertSound()
    {
        _alertSound = !_alertSound;
        try { await SettingsSvc.SetAsync(AlertSoundKey, _alertSound ? "true" : "false"); } catch { }
        StateHasChanged();
    }

    // ── Advanced settings form (deck Control tab; descriptor-driven, optimistic + refetch-to-reconcile) ──
    private bool _settingsOpen;
    private int _settingsPid;                                             // pid the loaded values belong to
    private Dictionary<string, System.Text.Json.JsonElement>? _settingsValues;
    private bool _settingsLoading;
    private string? _settingsError;
    private string _settingsSearch = "";
    private readonly HashSet<string> _settingsGroupsOpen = new();
    private readonly Dictionary<string, object> _setPending = new();      // optimistic value per setting key
    private readonly Dictionary<string, DateTime> _setPendingAt = new();
    private readonly Dictionary<string, int> _setSeq = new();             // per-key debounce token

    private async Task ToggleSettings(int pid)
    {
        _settingsOpen = !_settingsOpen;
        if (_settingsOpen && (_settingsValues == null || _settingsPid != pid)) await LoadSettings(pid, silent: false);
        StateHasChanged();
    }

    private async Task LoadSettings(int pid, bool silent)
    {
        if (string.IsNullOrWhiteSpace(_url)) { _settingsError = "Set your StatusAgent URL first."; if (!silent) StateHasChanged(); return; }
        _settingsPid = pid;
        if (!silent) { _settingsLoading = true; _settingsError = null; StateHasChanged(); }
        var r = await Status.GetSettingsAsync(_url, _token, pid, _cts?.Token ?? CancellationToken.None);
        if (!silent) _settingsLoading = false;
        if (r.Ok) { _settingsValues = r.Values ?? new(); _settingsError = null; ReconcileSetPending(); }
        else if (!silent) _settingsError = r.Error;
        if (!_disposed) StateHasChanged();
    }

    // Drop optimistic pendings the server now confirms (value matches) or that have timed out (~8s).
    private void ReconcileSetPending()
    {
        if (_setPending.Count == 0) return;
        var done = new List<string>();
        foreach (var kv in _setPending)
        {
            bool timedOut = !_setPendingAt.TryGetValue(kv.Key, out var t) || (DateTime.UtcNow - t).TotalSeconds > 8;
            if (timedOut) { done.Add(kv.Key); continue; }
            if (_settingsValues != null && _settingsValues.TryGetValue(kv.Key, out var el) && SettingEquals(el, kv.Value)) done.Add(kv.Key);
        }
        foreach (var k in done) { _setPending.Remove(k); _setPendingAt.Remove(k); }
    }

    private static bool SettingEquals(System.Text.Json.JsonElement el, object pending)
    {
        try
        {
            return pending switch
            {
                bool b => (el.ValueKind == System.Text.Json.JsonValueKind.True && b) || (el.ValueKind == System.Text.Json.JsonValueKind.False && !b),
                _ when el.ValueKind == System.Text.Json.JsonValueKind.Number => Math.Abs(el.GetDouble() - Convert.ToDouble(pending)) < 0.001,
                _ => false,
            };
        }
        catch { return false; }
    }

    private double CurNum(AcSettingDescriptor d)
    {
        if (_setPending.TryGetValue(d.Key, out var p)) { try { return Convert.ToDouble(p); } catch { } }
        if (_settingsValues != null && _settingsValues.TryGetValue(d.Key, out var el) && el.ValueKind == System.Text.Json.JsonValueKind.Number) return el.GetDouble();
        return d.Min;
    }
    private bool CurBool(AcSettingDescriptor d)
    {
        if (_setPending.TryGetValue(d.Key, out var p) && p is bool pb) return pb;
        if (_settingsValues != null && _settingsValues.TryGetValue(d.Key, out var el)) return el.ValueKind == System.Text.Json.JsonValueKind.True;
        return false;
    }
    private int CurEnum(AcSettingDescriptor d) => (int)Math.Round(CurNum(d));
    private string CurText(AcSettingDescriptor d)
    {
        if (_settingsValues != null && _settingsValues.TryGetValue(d.Key, out var el))
            return el.ValueKind == System.Text.Json.JsonValueKind.String ? (el.GetString() ?? "") : el.ToString();
        return "—";
    }
    private string FmtNum(AcSettingDescriptor d)
        => d.Type == AcSettingType.Float ? CurNum(d).ToString("0.##", CI) : ((int)Math.Round(CurNum(d))).ToString(CI);
    private bool IsSetPending(string key) => _setPending.ContainsKey(key);
    private bool SettingsMatch(AcSettingDescriptor d)
        => string.IsNullOrWhiteSpace(_settingsSearch)
           || d.Label.Contains(_settingsSearch, StringComparison.OrdinalIgnoreCase)
           || d.Key.Contains(_settingsSearch, StringComparison.OrdinalIgnoreCase);

    private void ToggleSettingsGroup(string g) { if (!_settingsGroupsOpen.Add(g)) _settingsGroupsOpen.Remove(g); StateHasChanged(); }

    private void ToggleSetting(AcSettingDescriptor d)
    {
        bool nv = !CurBool(d);
        if (d.Key == AcSettingsSchema.BuffingKey && !nv)   // never turn buffing OFF from the phone (keeps you alive)
        {
            _cmdMsg[_settingsPid] = "Turn buffing OFF in-game — blocked from the phone for safety.";
            StateHasChanged(); _ = ClearMsgLater(_settingsPid);
            return;
        }
        _ = QueueSetSetting(_settingsPid, d, nv);
    }
    private void StepSetting(AcSettingDescriptor d, int dir)
    {
        double nv = Math.Clamp(CurNum(d) + dir * d.Step, d.Min, d.Max);
        object boxed = d.Type == AcSettingType.Float ? nv : (object)(int)Math.Round(nv);
        _ = QueueSetSetting(_settingsPid, d, boxed);
    }
    private void SetEnum(AcSettingDescriptor d, int idx) { _ = QueueSetSetting(_settingsPid, d, idx); }

    // Optimistic: flip the displayed value now; debounce stepper spam; send; refetch ~0.9s later to reconcile.
    private async Task QueueSetSetting(int pid, AcSettingDescriptor d, object value)
    {
        _setPending[d.Key] = value; _setPendingAt[d.Key] = DateTime.UtcNow;
        int seq = (_setSeq.TryGetValue(d.Key, out var s) ? s : 0) + 1; _setSeq[d.Key] = seq;
        StateHasChanged();
        int debounce = d.Type is AcSettingType.Int or AcSettingType.Float ? 450 : 0;
        if (debounce > 0) { try { await Task.Delay(debounce, _cts?.Token ?? CancellationToken.None); } catch { return; } }
        if (!_setSeq.TryGetValue(d.Key, out var cur) || cur != seq) return;   // superseded by a newer change
        object send = _setPending.TryGetValue(d.Key, out var lv) ? lv : value;
        await Status.SetSettingAsync(_url, _token, pid, d.Key, send, _cts?.Token ?? CancellationToken.None);
        _setPendingAt[d.Key] = DateTime.UtcNow;
        _ = RefetchSettingsSoon(pid);
    }
    private async Task RefetchSettingsSoon(int pid)
    {
        try { await Task.Delay(900, _cts?.Token ?? CancellationToken.None); } catch { return; }
        if (!_disposed && _settingsOpen && _deckPid == pid) await LoadSettings(pid, silent: true);
    }
    private void ResetSettingsForm()   // on deck open/close/page — don't carry one client's form state to the next
    {
        _settingsOpen = false; _settingsValues = null; _settingsError = null; _settingsSearch = "";
        _setPending.Clear(); _setPendingAt.Clear(); _settingsGroupsOpen.Clear();
        _clickArmed = false;   // each deck starts with remote-click disarmed (safety)
    }

    // ── Fleet overview (collapsible glance-rows + roll-up state filter) ──
    private string _fleetFilter = "";                  // "" = all; otherwise a state string
    private int _deckPid;                               // open drill-in deck client (0 = fleet overview)

    private void OpenDeck(int pid) { _deckPid = pid; _deckTab = "Status"; ResetSettingsForm(); StateHasChanged(); }
    private void CloseDeck() { ReleaseDeckHeld(); _deckPid = 0; ResetSettingsForm(); StateHasChanged(); }

    // Sub-tabs (deck-scoped; one deck open at a time). Reset to Status on every open/page so paging
    // never lands on a stale "Live" tab and silently re-mounts the HD overlay on an arbitrary client.
    private string _deckTab = "Status";
    private bool _chatJustOpened;                // snap the chat log to the newest line when the Chat tab opens
    private static readonly string[] DeckTabs = { "Status", "Control", "Live", "Chat" };
    private async Task SetDeckTab(string tab)
    {
        if (_deckTab == tab) return;
        ReleaseDeckHeld();          // release the d-pad BEFORE the Live panel (and d-pad) unmounts
        if (tab == "Chat") _chatJustOpened = true;
        _deckTab = tab;
        await InvokeAsync(StateHasChanged);   // → OnAfterRenderAsync → ReconcileHdOverlay (hides/shows HD)
    }

    // Release any held d-pad button for the open deck pid (it's about to leave the DOM via tab-switch /
    // paging / close). Mirrors OnSuspended: tiny lock scope, SendMove(stop) OUTSIDE the lock; the plugin
    // dead-man's switch backstops a dropped stop POST.
    private void ReleaseDeckHeld()
    {
        if (_deckPid == 0) return;
        bool wasHeld;
        lock (_moveLock) wasHeld = _held.Remove(_deckPid);
        if (wasHeld) SendMove(_deckPid, "stop", false);
    }

    // Clients in the same order the fleet list shows them (trouble-first), for the deck's ‹ › paging.
    private List<AcClientStatus> OrderedClients()
    {
        var clients = _result?.Payload?.Clients;
        return clients == null ? new() : FilterClients(clients).OrderByDescending(c => !c.Healthy).ThenBy(c => c.Character).ToList();
    }
    private string DeckPos(int pid)
    {
        var list = OrderedClients();
        int i = list.FindIndex(c => c.Pid == pid);
        return i < 0 ? "" : $"{i + 1}/{list.Count}";
    }
    private void DeckStep(int dir)
    {
        var list = OrderedClients();
        if (list.Count == 0) return;
        ReleaseDeckHeld();                                          // release the OLD pid's d-pad before paging
        int i = list.FindIndex(c => c.Pid == _deckPid);
        int n = i < 0 ? 0 : ((i + dir) % list.Count + list.Count) % list.Count;   // wrap around
        _deckPid = list[n].Pid;
        _deckTab = "Status";
        ResetSettingsForm();
        StateHasChanged();
    }

    private void SetFleetFilter(string key)
    {
        _fleetFilter = (_fleetFilter == key) ? "" : key;   // tap the active chip again to clear
        StateHasChanged();
    }

    private IEnumerable<AcClientStatus> FilterClients(IEnumerable<AcClientStatus> clients)
        => string.IsNullOrEmpty(_fleetFilter)
            ? clients
            : clients.Where(c => string.Equals(c.State, _fleetFilter, StringComparison.OrdinalIgnoreCase));

    private List<(string Key, int Count, bool Attn)> FleetGroups(List<AcClientStatus> clients)
        => clients.GroupBy(c => string.IsNullOrEmpty(c.State) ? "unknown" : c.State)
                  .Select(g => (Key: g.Key, Count: g.Count(), Attn: g.Any(c => !c.Healthy)))
                  .OrderByDescending(g => g.Attn).ThenBy(g => g.Key)
                  .ToList();

    private readonly HashSet<int> _showGear = new();             // pids whose gear list is expanded
    private void ToggleGear(int pid) { if (!_showGear.Add(pid)) _showGear.Remove(pid); }
    private readonly HashSet<uint> _showItem = new();            // item ids whose appraisal is expanded
    private void ToggleItem(uint id) { if (!_showItem.Add(id)) _showItem.Remove(id); }

    // ── Inventory (AC-style parchment popup; its own on-demand /inventory fetch — NOT in the status
    // feed, so 100s of items never ride the live push). One modal open at a time. ──
    private readonly HashSet<int> _invLoading = new();                       // pids with an in-flight fetch
    private readonly Dictionary<int, AcInventoryPayload> _invByPid = new();  // last fetched inventory per pid
    private readonly Dictionary<int, string> _invError = new();             // last fetch error per pid
    private int _invModalPid;            // pid of the open inventory modal (0 = closed)
    private string _invModalName = "";   // character name shown in the modal title
    private uint _invTabId;              // selected container (pack) in the modal
    private uint _invSelItem;            // selected item for the examine panel (0 = none)
    private readonly HashSet<uint> _assessing = new();   // item ids with a tap-to-appraise Assess in flight

    private async Task OpenInvModal(int pid)
    {
        _invModalPid = pid;
        _invModalName = ClientName(pid);
        _invTabId = 0; _invSelItem = 0;
        StateHasChanged();
        await LoadInventoryAsync(pid);
        // Default tab = Main Pack if present, else the first container.
        if (_invByPid.TryGetValue(pid, out var inv) && inv.Containers.Count > 0)
            _invTabId = (inv.Containers.FirstOrDefault(x => x.Kind == "main") ?? inv.Containers[0]).Id;
        if (!_disposed) StateHasChanged();
    }

    private void CloseInvModal() { _invModalPid = 0; _invSelItem = 0; StateHasChanged(); }
    private void SelectTab(uint containerId) { _invTabId = containerId; _invSelItem = 0; StateHasChanged(); }

    /// Tap an item: select it for the examine panel, and if it isn't appraised yet, fire ONE Assess
    /// (tap-to-appraise) and re-fetch shortly to pick up the appraisal the engine cached.
    private async Task SelectInvItem(AcInventoryItem it)
    {
        _invSelItem = it.Id;
        if (it.HasAppraisal || _invModalPid == 0 || string.IsNullOrWhiteSpace(_url)) { StateHasChanged(); return; }
        if (!_assessing.Add(it.Id)) { StateHasChanged(); return; }   // an Assess for this item is already in flight
        StateHasChanged();
        int pid = _invModalPid;
        await Status.PostCommandAsync(_url, _token, pid, "assess", it.Id.ToString(), _cts?.Token ?? CancellationToken.None);
        // plugin Assess → 0xC9 → engine cache → RynthAi ~3s scan → file → agent. Re-fetch once after that.
        try { await Task.Delay(4000, _cts?.Token ?? CancellationToken.None); } catch { }
        if (!_disposed && _invModalPid == pid) await LoadInventoryAsync(pid);
        _assessing.Remove(it.Id);
        if (!_disposed) StateHasChanged();
    }

    private string ClientName(int pid)
        => _result?.Payload?.Clients?.FirstOrDefault(c => c.Pid == pid)?.DisplayName ?? $"PID {pid}";

    private async Task LoadInventoryAsync(int pid)
    {
        if (string.IsNullOrWhiteSpace(_url)) { _invError[pid] = "Set your StatusAgent URL first."; StateHasChanged(); return; }
        _invLoading.Add(pid); _invError.Remove(pid); StateHasChanged();
        var r = await Status.GetInventoryAsync(_url, _token, pid, _cts?.Token ?? CancellationToken.None);
        _invLoading.Remove(pid);
        if (r.Ok && r.Payload is not null) _invByPid[pid] = r.Payload;
        else _invError[pid] = r.Error ?? "Couldn't load inventory.";
        if (!_disposed) StateHasChanged();
    }

    private string InvCountLabel(int pid)
        => _invByPid.TryGetValue(pid, out var inv) && inv.ItemCount > 0 ? $" ({inv.ItemCount})" : "";

    // Chat tabs — the standard AC tab set, routed by message-type (AcChatLine.Route). The user's
    // exact in-game tab config isn't readable from the client, so this mirrors the default tabs.
    private static readonly string[] ChatTabs = { "All", "Chat", "Combat", "Channels", "System", "Rynth", "Other" };
    private readonly Dictionary<int, string> _chatTab = new();   // per-pid active tab (default "All")
    private string ChatTabFor(int pid) => _chatTab.TryGetValue(pid, out var t) ? t : "All";
    private void SetChatTab(int pid, string tab) => _chatTab[pid] = tab;
    private readonly Dictionary<int, string> _chatDraft = new();
    private string GetDraft(int pid) => _chatDraft.TryGetValue(pid, out var v) ? v : "";
    private async Task ChatKeyDown(KeyboardEventArgs e, AcClientStatus c) { if (e.Key == "Enter") await SendChat(c); }
    private async Task SendChat(AcClientStatus c)
    {
        string text = GetDraft(c.Pid);
        if (string.IsNullOrWhiteSpace(text)) return;
        _chatDraft[c.Pid] = string.Empty;
        StateHasChanged();
        await SendCommand(c, "sendChat", text);
    }

    // ── Movement d-pad (hold-to-move) ────────────────────────────────────────
    // pid → the SET of directions currently held. A set (not one slot) so you can run AND steer at the
    // same time, with each held direction independently kept alive + released. _moveLock guards _held /
    // _moveChain because the keepalive timer thread touches them alongside the renderer thread.
    private readonly Dictionary<int, HashSet<string>> _held = new();
    private readonly object _moveLock = new();
    private string Held(int pid, string dir)
    {
        lock (_moveLock) return _held.TryGetValue(pid, out var s) && s.Contains(dir) ? "held" : "";
    }

    private void StartMove(AcClientStatus c, string dir)
    {
        lock (_moveLock)
        {
            if (!_held.TryGetValue(c.Pid, out var s)) _held[c.Pid] = s = new();
            s.Add(dir);
        }
        SendMove(c.Pid, dir, true);
    }

    private void StopMove(AcClientStatus c, string dir)
    {
        bool nowEmpty = false;
        lock (_moveLock)
            if (_held.TryGetValue(c.Pid, out var s) && s.Remove(dir) && s.Count == 0) { _held.Remove(c.Pid); nowEmpty = true; }
        // Releasing the LAST held direction → send a full "stop": it releases everything AND disarms the
        // plugin dead-man immediately, so the watchdog can't fire a delayed stop later that would clobber
        // the bot if it re-took control. A non-last release just drops that one direction (others keep going).
        SendMove(c.Pid, nowEmpty ? "stop" : dir, false);
    }

    private void HardStop(AcClientStatus c)
    {
        lock (_moveLock) _held.Remove(c.Pid);
        SendMove(c.Pid, "stop", false);
    }

    // Keepalive: while a direction is held we re-assert EACH held direction on a heartbeat so the
    // plugin's dead-man's switch stays fed. If anything cuts a held button off without a release
    // (pointercancel, app force-kill, Wi-Fi drop, page nav, card unmount), the heartbeat stops and the
    // plugin auto-stops shortly after. This is the real runaway backstop — a single release POST can
    // always be lost. Sends are coalesced (see SendMove) so a stalled POST can't starve the heartbeat.
    private const int KeepAliveMs = 300;
    private async Task KeepAliveLoopAsync(CancellationToken ct)
    {
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromMilliseconds(KeepAliveMs));
            while (await timer.WaitForNextTickAsync(ct))
            {
                (int pid, string dir)[] held;
                lock (_moveLock)
                {
                    if (_held.Count == 0) continue;
                    held = _held.SelectMany(kv => kv.Value.Select(d => (kv.Key, d))).ToArray();
                }
                foreach (var (pid, dir) in held)
                    SendMove(pid, dir, true, coalesce: true);   // skipped if a send for this pid is still in flight
            }
        }
        catch (OperationCanceledException) { /* disposed */ }
    }

    // Sends serialize PER PID so a release can't be overtaken by a stale keepalive (the agent stamps on
    // receipt and the plugin applies in that order). But they must NOT back-pressure: a stalled POST
    // can't be allowed to stack keepalives behind it — that starves the plugin watchdog (→ false stop),
    // then the queued burst flushes and *resumes* motion you released. So every send has a SHORT timeout
    // (well under the dead-man window) and keepalives COALESCE: a keepalive is dropped while this pid
    // still has a send in flight (the next tick retries). Explicit press/release always go through.
    private const int MoveSendTimeoutMs = 1000;
    private readonly Dictionary<int, Task> _moveChain = new();
    private void SendMove(int pid, string dir, bool start, bool coalesce = false)
    {
        lock (_moveLock)
        {
            if (coalesce && _moveChain.TryGetValue(pid, out var cur) && !cur.IsCompleted) return;
            Task prev = _moveChain.TryGetValue(pid, out var t) ? t : Task.CompletedTask;
            _moveChain[pid] = ChainSend(prev, pid, start ? "moveStart" : "moveStop", dir);
        }
    }

    private async Task ChainSend(Task prev, int pid, string action, string dir)
    {
        try { await prev; } catch { /* prior send never throws, but stay defensive */ }
        using var cts = new CancellationTokenSource(MoveSendTimeoutMs);   // bound a stalled POST well under the watchdog
        await Status.PostCommandAsync(_url, _token, pid, action, dir, cts.Token);
    }

    // A pid can leave the feed (box relaunched → new pid, or dropped on a transient agent error) while
    // a button is held. The held element is unmounted with no pointer-up, so without this the keepalive
    // loop would keep feeding the watchdog and sustain the very runaway it guards against. Release +
    // forget any held/queued pid no longer present, so the heartbeat stops and the plugin can self-stop.
    private void ReconcileHeldWithFeed()
    {
        var live = _result?.Payload?.Clients;
        if (live is null) return;
        int[] goneHeld;
        lock (_moveLock)
        {
            goneHeld = _held.Keys.Where(pid => !live.Any(x => x.Pid == pid)).ToArray();
            foreach (var pid in goneHeld) _held.Remove(pid);
            foreach (var pid in _moveChain.Keys.ToArray())      // prune completed chains for gone pids
                if (!_held.ContainsKey(pid) && !live.Any(x => x.Pid == pid)) _moveChain.Remove(pid);
        }
        foreach (var pid in goneHeld) SendMove(pid, "stop", false);
    }

    protected override async Task OnInitializedAsync()
    {
        _url = await SettingsSvc.GetAsync(UrlKey, "");
        _token = await SettingsSvc.GetAsync(TokenKey);
        _urlEdit = _url;
        _tokenEdit = _token ?? "";
        if (int.TryParse(await SettingsSvc.GetAsync(PresetKey, "1"), out int pi))
            _defaultPreset = Math.Clamp(pi, 0, Presets.Length - 1);
        _alertSound = await SettingsSvc.GetAsync(AlertSoundKey, "false") == "true";
        _lbMetric = await SettingsSvc.GetAsync(LbMetricKey, "khr");
        _alertsNeedRebase = true;   // rebaseline (no fire) on the first snapshot
        StreamLifecycle.Resumed += OnResumed;
        StreamLifecycle.Suspended += OnSuspended;
        _cts = new CancellationTokenSource();
        _ = FeedLoopAsync(_cts.Token);     // low-latency WS push (primary)
        _ = PollLoopAsync(_cts.Token);     // HTTP poll (bootstrap + fallback when the push path is down)
        _ = KeepAliveLoopAsync(_cts.Token);
    }

    private async Task PollLoopAsync(CancellationToken ct)
    {
        try
        {
            while (!ct.IsCancellationRequested)
            {
                // Back off while the /statusfeed WS is delivering — it already keeps _result live, so this
                // is the bootstrap + fallback, not a redundant second fetch. Recheck soon so a WS drop is
                // picked up within ~2s and the poll takes over.
                if ((DateTime.UtcNow - _lastFeedAtUtc).TotalSeconds < 4) { await Task.Delay(2000, ct); continue; }

                bool ok = await RefreshOnceAsync(ct);
                // Snappy numbers while you're actively watching/driving (a live view open or a movement
                // button held); easy on cellular data when you're just glancing at the list. After a
                // failed/stalled poll, retry soon so one bad fetch over Tailscale can't compound into a
                // long gap (the ~20s symptom: an 8s stall + a full 4s wait used to stack up).
                bool engaged = _streaming.Count > 0 || _deckPid != 0;   // streaming, or a deck open (actively watching one client)
                lock (_moveLock) engaged |= _held.Count > 0;                  // or a movement button held
                int delayMs = !ok ? 1000 : engaged ? 1000 : 3000;
                await Task.Delay(delayMs, ct);
            }
        }
        catch (OperationCanceledException) { /* disposed */ }
    }

    private async Task<bool> RefreshOnceAsync(CancellationToken ct)
    {
        if (string.IsNullOrWhiteSpace(_url)) return false;
        var requestedUrl = _url;   // so a response that lands after a config change is discarded
        try
        {
            var r = await Status.GetStatusAsync(_url, _token, ct);
            // Bail if the page is gone, the poll was cancelled, or the URL changed mid-flight
            // (a stale old-host response must not overwrite the freshly-switched view).
            if (_disposed || ct.IsCancellationRequested
                || !string.Equals(requestedUrl, _url, StringComparison.Ordinal)) return false;
            _result = r;
            ReconcilePending();   // clear optimistic toggle states the feed now confirms
            ProcessAlerts(r);     // raise an in-app alert on any healthy→critical transition
            if (_held.Count > 0) ReconcileHeldWithFeed();   // release any held pid that just left the feed
            await InvokeAsync(StateHasChanged);
            return r.Payload is not null;   // false on a network/agent failure → loop retries soon
        }
        catch (OperationCanceledException) { return false; /* cancelled (page disposed / config change) */ }
        catch (ObjectDisposedException) { return false; /* circuit/renderer torn down mid-render */ }
    }

    // Low-latency path: hold the agent's /statusfeed WebSocket open and apply each pushed snapshot the
    // instant it lands (~150ms after the box writes it), instead of waiting for the next poll. On any drop
    // it falls through to the poll loop (which covers the gap) and re-opens the socket after a short backoff.
    private async Task FeedLoopAsync(CancellationToken ct)
    {
        try
        {
            while (!ct.IsCancellationRequested)
            {
                string url = _url;
                if (string.IsNullOrWhiteSpace(url)) { await Task.Delay(1000, ct); continue; }

                using var conn = CancellationTokenSource.CreateLinkedTokenSource(ct);
                _feedConnCts = conn;   // SaveConfig cancels this to force a reconnect on a changed URL
                try
                {
                    await Status.StreamStatusAsync(url, _token, r =>
                    {
                        // Drop a stale push from a host we've since switched away from (URL changed mid-connection).
                        if (_disposed || !string.Equals(url, _url, StringComparison.Ordinal)) return;
                        _lastFeedAtUtc = DateTime.UtcNow;
                        _result = r;
                        ReconcilePending();   // clear optimistic toggle states the feed now confirms
                        ProcessAlerts(r);     // raise an in-app alert on any healthy→critical transition
                        if (r.Payload is not null && _held.Count > 0) ReconcileHeldWithFeed();
                        _ = InvokeAsync(StateHasChanged);
                    }, conn.Token);
                }
                catch (OperationCanceledException) when (ct.IsCancellationRequested) { break; }
                catch { /* socket unavailable / dropped — the poll loop is covering us */ }

                if (ct.IsCancellationRequested) break;
                await Task.Delay(2000, ct);   // brief backoff before re-opening the socket
            }
        }
        catch (OperationCanceledException) { /* page disposed */ }
    }

    private Task Refresh() => RefreshOnceAsync(_cts?.Token ?? CancellationToken.None);

    private void ToggleConfig() => _showConfig = !_showConfig;

    private async Task SaveConfig()
    {
        _url = _urlEdit?.Trim() ?? "";
        _token = string.IsNullOrWhiteSpace(_tokenEdit) ? null : _tokenEdit.Trim();
        await SettingsSvc.SetAsync(UrlKey, _url);
        await SettingsSvc.SetAsync(TokenKey, _token ?? "");
        _savedConfig = true;
        _showConfig = false;
        _result = null;
        _alertsNeedRebase = true;       // new host → rebaseline alerts on the first snapshot, don't fire
        _runs = null; _runsError = null;           // drop cached run history; it reloads against the new host
        _maps = null; _mapsError = null;           // drop cached map list; it reloads against the new host
        _lastFeedAtUtc = DateTime.MinValue;        // let the poll take over until the feed reconnects
        try { _feedConnCts?.Cancel(); } catch { }  // drop the old-host WS; the feed loop re-opens on the new URL
        if (_view == "archive") await LoadRunsAsync();
        else if (_view == "maps") await LoadMapsAsync();
        await RefreshOnceAsync(_cts?.Token ?? CancellationToken.None);
    }

    private static RenderFragment Bar(string label, uint cur, uint max, string color, string gem = "") => __builder =>
    {
        int pct = max > 0 ? (int)Math.Clamp(Math.Round(cur * 100.0 / max), 0, 100) : 0;
        <div class="ac-vlabel"><span>@label</span><span>@cur/@max</span></div>
        <div class="ac-bar @(gem.Length > 0 ? "gem gem-" + gem : "")"><span style="width:@pct%;background:@color"></span></div>
    };

    private static RenderFragment Stat(string label, string value, bool warn = false) => __builder =>
    {
        <div class="ac-stat"><div class="sv@(warn ? " warn" : "")">@value</div><div class="sl">@label</div></div>
    };

    // ── Remote control ──────────────────────────────────────────────────────
    private static IEnumerable<(string Action, string Label, bool On)> Toggles(AcClientStatus c) =>
        new[]
        {
            ("navigation", "Nav", c.NavigationEnabled),
            ("combat", "Combat", c.CombatEnabled),
            ("buffing", "Buff", c.BuffingEnabled),
            ("looting", "Loot", c.LootingEnabled),
            ("meta", "Meta", c.MetaEnabled),
        };

    private static string Trunc(string s) => string.IsNullOrEmpty(s) ? s : (s.Length <= 14 ? s : s[..13] + "…");

    private async Task CmdProfile(AcClientStatus c, string action, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int idx))
            await SendCommand(c, action, idx.ToString());
    }

    // ── Optimistic control feedback ──
    // Tapping a stateful toggle (macro / the 5 modes / hideUi) flips its visual immediately and shows an
    // "applying" shimmer until the live feed confirms the new value (or a short timeout) — so a tap never
    // feels dead and you don't double-tap. The feed stays the source of truth; pending only overrides the
    // DISPLAY until reconciled.
    private readonly Dictionary<string, bool> _pending = new();          // "pid:action" -> intended value
    private readonly Dictionary<string, DateTime> _pendingAt = new();
    private static string PKey(int pid, string action) => pid + ":" + action;
    private bool EffOn(int pid, string action, bool actual)
        => _pending.TryGetValue(PKey(pid, action), out bool v) ? v : actual;
    private bool IsApplying(int pid, string action) => _pending.ContainsKey(PKey(pid, action));

    private static bool? ActualToggle(AcClientStatus c, string action) => action switch
    {
        "macro" => c.MacroRunning,
        "combat" => c.CombatEnabled,
        "buffing" => c.BuffingEnabled,
        "navigation" => c.NavigationEnabled,
        "looting" => c.LootingEnabled,
        "meta" => c.MetaEnabled,
        "hideUi" => c.UiHidden,
        _ => null,
    };

    // Drop pendings the feed has confirmed (actual == intended) or that have timed out (~6s, so a dropped
    // command can't pin a wrong display forever). Called whenever a fresh payload lands.
    private void ReconcilePending()
    {
        if (_pending.Count == 0) return;
        var clients = _result?.Payload?.Clients;
        List<string>? done = null;
        foreach (var kv in _pending)
        {
            int sep = kv.Key.IndexOf(':');
            int pid = int.Parse(kv.Key.AsSpan(0, sep));
            string action = kv.Key[(sep + 1)..];
            bool timedOut = !_pendingAt.TryGetValue(kv.Key, out var t) || (DateTime.UtcNow - t).TotalSeconds > 6;
            var c = clients?.FirstOrDefault(x => x.Pid == pid);
            bool? actual = c == null ? null : ActualToggle(c, action);
            if (timedOut || (actual.HasValue && actual.Value == kv.Value)) (done ??= new()).Add(kv.Key);
        }
        if (done != null) foreach (var k in done) { _pending.Remove(k); _pendingAt.Remove(k); }
    }

    private async Task SendCommand(AcClientStatus c, string action, string value)
    {
        if (ActualToggle(c, action) != null && (value == "true" || value == "false"))
        {
            _pending[PKey(c.Pid, action)] = value == "true";        // optimistic flip, confirmed/cleared by the feed
            _pendingAt[PKey(c.Pid, action)] = DateTime.UtcNow;
        }
        _cmdMsg[c.Pid] = "sending…";
        StateHasChanged();
        var r = await Status.PostCommandAsync(_url, _token, c.Pid, action, value);
        _cmdMsg[c.Pid] = r.Ok ? "✓ sent" : ("✗ " + r.Error);
        StateHasChanged();
        if (r.Ok)
        {
            // Give the box ~1.2s to poll, apply, and rewrite its status file, then refresh so the
            // switch positions reflect reality (the feed is the source of truth, not optimistic local state).
            try { await Task.Delay(1200, _cts?.Token ?? CancellationToken.None); } catch { }
            if (!_disposed) await RefreshOnceAsync(_cts?.Token ?? CancellationToken.None);
        }
        _ = ClearMsgLater(c.Pid);
    }

    private async Task ClearMsgLater(int pid)
    {
        try { await Task.Delay(3000); } catch { }
        if (_disposed) return;
        _cmdMsg.Remove(pid);
        await InvokeAsync(StateHasChanged);
    }

    // Compact rate: 1.2M / 450k / 87.
    private static string FmtRate(double v)
    {
        if (v >= 1_000_000) return (v / 1_000_000).ToString("0.0") + "M";
        if (v >= 1_000) return (v / 1_000).ToString("0.0") + "k";
        return v.ToString("F0");
    }

    // Compact elapsed: "—" (none) / "12s" / "4m" / "2h".
    private static string Since(int seconds)
    {
        if (seconds < 0) return "—";
        if (seconds < 60) return $"{seconds}s";
        if (seconds < 3600) return $"{seconds / 60}m";
        return $"{seconds / 3600}h";
    }

    // Highlight "last kill" when a botting client hasn't killed anything in a while —
    // the clearest "is it stuck?" signal. Only meaningful once combat is enabled.
    private static bool StaleKill(AcClientStatus c)
        => c.SecsSinceLastKill >= 180
           && string.Equals(c.State, "botting", StringComparison.OrdinalIgnoreCase);

    private static string StateColor(string state) => state switch
    {
        "botting"           => "#34d399",
        "idle" or "running" => "#60a5fa",
        "loading"           => "#fbbf24",
        "wedged" or "hung" or "dead" => "#f87171",
        _ => "#94a3b8",
    };

    private static string Dur(long seconds)
    {
        var t = TimeSpan.FromSeconds(seconds);
        return t.TotalHours >= 1 ? $"{(int)t.TotalHours}h{t.Minutes:D2}m" : $"{t.Minutes}m";
    }

    private static string Ago(DateTimeOffset? ts)
    {
        if (ts is null) return "—";
        var s = (DateTimeOffset.UtcNow - ts.Value).TotalSeconds;
        return s < 0 ? "now" : s < 60 ? $"{(int)s}s ago" : $"{(int)(s / 60)}m ago";
    }

    public ValueTask DisposeAsync()
    {
        _disposed = true;
        // Page being torn down (nav away / back) while a button is held fires no pointer-up — release
        // every held pid before we cancel the loops. Fire-and-forget; the plugin dead-man backstops it.
        int[] pids;
        lock (_moveLock) { pids = _held.Keys.ToArray(); _held.Clear(); }
        foreach (var pid in pids) SendMove(pid, "stop", false);
        // Tear down the inline HD overlay (native video) + its rect tracker.
        if (_hdShownPid != null) { HdController.Hide(); try { _ = JS.InvokeVoidAsync("rynthHd.stopTrack"); } catch { } _hdShownPid = null; }
        _hdRef?.Dispose(); _hdRef = null;
        _closeCts?.Cancel();
        _fleetCts?.Cancel();
        StreamLifecycle.Resumed -= OnResumed;
        StreamLifecycle.Suspended -= OnSuspended;
        _cts?.Cancel();
        _cts?.Dispose();
        _cts = null;
        return ValueTask.CompletedTask;
    }
}
