    };

    // ── Remote control ──────────────────────────────────────────────────────
    private static IEnumerable<(string Action, string Label, bool On)> Toggles(AcClientStatus c) =>
        new[]
        {
            ("navigation", "Nav", c.NavigationEnabled),
            ("combat", "Combat", c.CombatEnabled),
            ("buffing", "Buff", c.BuffingEnabled),
            ("looting", "Loot", c.LootingEnabled),
            ("meta", "Meta", c.MetaEnabled),
        };

    private static string Trunc(string s) => string.IsNullOrEmpty(s) ? s : (s.Length <= 14 ? s : s[..13] + "…");

    private async Task CmdProfile(AcClientStatus c, string action, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int idx))
            await SendCommand(c, action, idx.ToString());
    }

    private async Task SendCommand(AcClientStatus c, string action, string value)
    {
        _cmdMsg[c.Pid] = "sending…";
        StateHasChanged();
        var r = await Status.PostCommandAsync(_url, _token, c.Pid, action, value);
        _cmdMsg[c.Pid] = r.Ok ? "✓ sent" : ("✗ " + r.Error);
        StateHasChanged();
        if (r.Ok)
        {
            // Give the box ~1.2s to poll, apply, and rewrite its status file, then refresh so the
            // switch positions reflect reality (the feed is the source of truth, not optimistic local state).
            try { await Task.Delay(1200, _cts?.Token ?? CancellationToken.None); } catch { }
            if (!_disposed) await RefreshOnceAsync(_cts?.Token ?? CancellationToken.None);
        }
        _ = ClearMsgLater(c.Pid);
    }

    private async Task ClearMsgLater(int pid)
    {
        try { await Task.Delay(3000); } catch { }
        if (_disposed) return;
        _cmdMsg.Remove(pid);
        await InvokeAsync(StateHasChanged);
    }

    // Compact rate: 1.2M / 450k / 87.
    private static string FmtRate(double v)
    {
        if (v >= 1_000_000) return (v / 1_000_000).ToString("0.0") + "M";
        if (v >= 1_000) return (v / 1_000).ToString("0.0") + "k";
        return v.ToString("F0");
    }

    // Compact elapsed: "—" (none) / "12s" / "4m" / "2h".
    private static string Since(int seconds)
    {
        if (seconds < 0) return "—";
        if (seconds < 60) return $"{seconds}s";
        if (seconds < 3600) return $"{seconds / 60}m";
        return $"{seconds / 3600}h";
    }

    // Highlight "last kill" when a botting client hasn't killed anything in a while —
    // the clearest "is it stuck?" signal. Only meaningful once combat is enabled.
    private static bool StaleKill(AcClientStatus c)
        => c.SecsSinceLastKill >= 180
           && string.Equals(c.State, "botting", StringComparison.OrdinalIgnoreCase);

    private static string StateColor(string state) => state switch
    {
        "botting"           => "#34d399",
        "idle" or "running" => "#60a5fa",
        "loading"           => "#fbbf24",
        "wedged" or "hung" or "dead" => "#f87171",
        _ => "#94a3b8",
    };

    private static string Dur(long seconds)
    {
        var t = TimeSpan.FromSeconds(seconds);
        return t.TotalHours >= 1 ? $"{(int)t.TotalHours}h{t.Minutes:D2}m" : $"{t.Minutes}m";
    }

    private static string Ago(DateTimeOffset? ts)
    {
        if (ts is null) return "—";
        var s = (DateTimeOffset.UtcNow - ts.Value).TotalSeconds;
        return s < 0 ? "now" : s < 60 ? $"{(int)s}s ago" : $"{(int)(s / 60)}m ago";
    }

    public ValueTask DisposeAsync()
    {
        _disposed = true;
        // Page being torn down (nav away / back) while a button is held fires no pointer-up — release
        // every held pid before we cancel the loops. Fire-and-forget; the plugin dead-man backstops it.
        int[] pids;
        lock (_moveLock) { pids = _held.Keys.ToArray(); _held.Clear(); }
        foreach (var pid in pids) SendMove(pid, "stop", false);
        // Tear down the inline HD overlay (native video) + its rect tracker.
        if (_hdShownPid != null) { HdController.Hide(); try { _ = JS.InvokeVoidAsync("rynthHd.stopTrack"); } catch { } _hdShownPid = null; }
        _hdRef?.Dispose(); _hdRef = null;
        StreamLifecycle.Resumed -= OnResumed;
        StreamLifecycle.Suspended -= OnSuspended;
        _cts?.Cancel();
        _cts?.Dispose();
        _cts = null;
        return ValueTask.CompletedTask;
    }
}
