@page "/"
@page "/clients"
@using RynthRemote.AcStatus
@inject IAcStatusClient Status
@inject SettingsStore SettingsSvc
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>AC Clients - MicroManager</PageTitle>

<style>
    .ac-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(250px,1fr)); gap:.75rem; }
    .ac-card { border:1px solid var(--border); border-radius:10px; padding:.7rem .8rem; background:var(--surface); }
    .ac-card.bad { border-color:var(--red); }
    .ac-head { display:flex; align-items:center; justify-content:space-between; gap:.5rem; }
    .ac-name { font-weight:700; }
    .ac-sub { color:var(--muted); font-size:.78rem; }
    .ac-badge { font-size:.7rem; font-weight:700; text-transform:uppercase; letter-spacing:.04em; padding:.15rem .45rem; border-radius:999px; color:#0b1120; }
    .ac-bar { height:12px; border-radius:6px; background:var(--surface-2); overflow:hidden; margin:.15rem 0; }
    .ac-bar > span { display:block; height:100%; }
    .ac-vlabel { display:flex; justify-content:space-between; font-size:.7rem; color:var(--muted); }
    .ac-doing { margin:.5rem 0 .25rem; font-size:.85rem; }
    .ac-stream-bar { margin:.35rem 0 .25rem; }
    .ac-stream { margin:.25rem 0 .45rem; border:1px solid var(--border); border-radius:8px; overflow:hidden; background:#000; aspect-ratio:16/10; }
    .ac-stream img, .ac-stream video { width:100%; height:100%; object-fit:contain; display:block; background:#000; }
    .ac-qsel { display:flex; gap:.3rem; align-items:center; flex-wrap:wrap; margin:.2rem 0 .6rem; padding:.4rem .5rem; background:var(--surface); border:1px solid var(--border); border-radius:8px; }
    .ac-qsel .lbl { font-size:.72rem; color:var(--muted); }
    .ac-stats { display:grid; grid-template-columns:repeat(auto-fit,minmax(56px,1fr)); gap:.3rem; margin:.4rem 0 .25rem; }
    .ac-stat { background:var(--surface-2); border-radius:6px; padding:.25rem .2rem; text-align:center; }
    .ac-stat .sv { font-weight:700; font-size:.9rem; font-variant-numeric:tabular-nums; line-height:1.1; }
    .ac-stat .sv.warn { color:var(--amber); }
    .ac-stat .sl { font-size:.6rem; color:var(--muted); text-transform:uppercase; letter-spacing:.03em; }
    .ac-foot { display:flex; flex-wrap:wrap; gap:.5rem .9rem; font-size:.72rem; color:var(--muted); margin-top:.4rem; }
    .ac-issue { font-size:.72rem; color:var(--amber); margin-top:.35rem; word-break:break-word; }
    .ac-warn { color:var(--amber); }
    .ac-ctrl { display:flex; flex-wrap:wrap; gap:.3rem; margin-top:.45rem; align-items:center; }
    .ac-pill { font-size:.72rem; padding:.22rem .55rem; border-radius:999px; border:1px solid var(--border); background:var(--surface-2); color:inherit; cursor:pointer; }
    .ac-pill:disabled { opacity:.5; cursor:default; }
    .ac-pill.on { background:#34d399; color:#06281c; border-color:transparent; font-weight:700; }
    .ac-pill.ac-macro.on { background:#f87171; color:#3a0b0b; }
    .ac-sel { font-size:.72rem; padding:.18rem .3rem; border-radius:6px; border:1px solid var(--border); background:var(--surface-2); color:inherit; flex:1 1 30%; min-width:0; }
    .ac-cmd-msg { font-size:.7rem; color:var(--muted); margin-top:.25rem; }
    .ac-pill.ac-danger { background:#f87171; color:#3a0b0b; border-color:transparent; font-weight:700; }
    .ac-gear { margin-top:.4rem; }
    .ac-gear-h { font-size:.74rem; background:none; border:none; color:var(--muted); cursor:pointer; padding:.1rem 0; }
    .ac-gear-list { display:flex; flex-direction:column; gap:.12rem; margin-top:.2rem; }
    .ac-gear-row { display:flex; justify-content:space-between; gap:.5rem; font-size:.72rem; }
    .ac-gear-row { cursor:pointer; }
    .ac-gear-row .gn { overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .ac-gear-row .gi { color:var(--muted); font-family:ui-monospace,monospace; user-select:all; white-space:nowrap; }
    .ac-chat { margin-top:.4rem; }
    .ac-chat-log { max-height:200px; overflow-y:auto; background:var(--bg); border:1px solid var(--border); border-radius:6px; padding:.35rem .45rem; display:flex; flex-direction:column; gap:.1rem; margin:.2rem 0; }
    .ac-chat-line { font-size:.74rem; line-height:1.25; word-break:break-word; }
    .ac-chat-send { display:flex; gap:.3rem; }
    .ac-chat-input { flex:1; min-width:0; background:var(--surface-2); border:1px solid var(--border); border-radius:6px; color:inherit; padding:.3rem .45rem; font-size:.85rem; }
    .ac-drive { margin-top:.4rem; }
    .ac-dpad { display:grid; grid-template-columns:repeat(3,1fr); grid-template-rows:repeat(3,1fr); gap:.35rem; max-width:230px; margin:.3rem auto .1rem; touch-action:none; }
    .ac-dbtn { display:flex; align-items:center; justify-content:center; aspect-ratio:1; font-size:1.5rem; line-height:1; background:var(--surface-2); border:1px solid var(--border); border-radius:10px; color:inherit; user-select:none; -webkit-user-select:none; -webkit-tap-highlight-color:transparent; cursor:pointer; }
    .ac-dbtn:active, .ac-dbtn.held { background:var(--accent); border-color:var(--accent); color:#0b1220; }
    .ac-dbtn.stop { font-size:1.05rem; color:var(--amber); }
    .ac-dnote { font-size:.7rem; color:var(--muted); text-align:center; }
    .ac-appr { font-size:.7rem; margin:.15rem 0 .35rem .6rem; padding-left:.5rem; border-left:2px solid var(--border); display:flex; flex-direction:column; gap:.15rem; }
    .ac-appr b { font-weight:700; }
    .ac-appr .rb { color:var(--amber); margin-left:.4rem; }
    .ac-appr .amono { color:var(--muted); display:flex; flex-wrap:wrap; gap:.5rem; }
    .ac-appr .aspells { display:flex; flex-wrap:wrap; gap:.25rem; }
    .ac-appr .aspells .sp { background:var(--surface-2); border-radius:4px; padding:.05rem .35rem; }
    .ac-appr .adesc { color:var(--muted); font-style:italic; }
</style>

<div class="card-head">
    <h1>&#127918; AC Clients</h1>
    <div class="flex" style="gap:.5rem">
        <button class="btn-r ghost sm" @onclick="() => _showControls = !_showControls">@(_showControls ? "Hide controls" : "Controls")</button>
        <button class="btn-r ghost sm" @onclick="ToggleConfig">@(_showConfig ? "Close" : "Connection")</button>
        <button class="btn-r ghost sm" @onclick="Refresh" disabled="@string.IsNullOrWhiteSpace(_url)">Refresh</button>
    </div>
</div>

@if (_showConfig || string.IsNullOrWhiteSpace(_url))
{
    <div class="card-r mb">
        <h3 style="margin-top:0">RynthCore StatusAgent</h3>
        <p class="muted" style="font-size:.82rem;margin-top:0">
            URL of your StatusAgent's pull endpoint, e.g. <code>http://your-pc:8740/status</code>
            (over Tailscale/LAN). Leave the token blank unless you set <code>ServeToken</code>.
        </p>
        <div class="field">
            <label>Status URL</label>
            <input @bind="_urlEdit" placeholder="http://your-pc:8740/status" />
        </div>
        <div class="field">
            <label>Token (optional)</label>
            <input @bind="_tokenEdit" placeholder="bearer token, if any" />
        </div>
        <div class="flex" style="gap:.5rem;margin-top:.5rem">
            <button class="btn-r" @onclick="SaveConfig">Save</button>
            @if (_savedConfig) { <span class="badge-r green">saved</span> }
        </div>
    </div>
}

@if (string.IsNullOrWhiteSpace(_url))
{
    <div class="card-r"><p class="muted">Set your StatusAgent URL above to see your AC clients.</p></div>
}
else if (_result is null)
{
    <p class="loading">Connecting to @_url …</p>
}
else if (!_result.Ok)
{
    <div class="card-r">
        <p class="ac-warn" style="margin-top:0">&#9888; @_result.Error</p>
        <p class="ac-sub">@_url — retrying every few seconds.</p>
    </div>
}
else
{
    var clients = _result.Payload!.Clients;
    var bad = clients.Count(c => !c.Healthy);

    <div class="card-r mb" style="border-left:4px solid @(bad > 0 ? "var(--red)" : "var(--green)")">
        <strong>@(clients.Count == 0 ? "No clients running"
                  : bad == 0 ? $"All {clients.Count} healthy"
                  : $"{bad} of {clients.Count} need attention")</strong>
        <span class="ac-sub" style="margin-left:.5rem">
            @_result.Payload.Host · updated @Ago(_result.Payload.GeneratedAtUtc)
        </span>
    </div>

    <div class="ac-grid">
        @foreach (var c in clients.OrderByDescending(c => !c.Healthy).ThenBy(c => c.Character))
        {
            <div class="ac-card @(c.Healthy ? "" : "bad")" @key="c.Pid">
                <div class="ac-head">
                    <div>
                        <div class="ac-name">@c.DisplayName</div>
                        <div class="ac-sub">@c.Server</div>
                    </div>
                    <span class="ac-badge" style="background:@StateColor(c.State)">@c.State</span>
                </div>

                @if (c.Player is { } v && v.MaxHp > 0)
                {
                    @Bar("HP", v.Hp, v.MaxHp, "#ef4444")
                    @Bar("Stam", v.St, v.MaxSt, "#22c55e")
                    @Bar("Mana", v.Mn, v.MaxMn, "#3b82f6")
                }

                <div class="ac-doing">
                    @if (!string.IsNullOrWhiteSpace(c.BotAction)) { <span>@c.BotAction</span> }
                    else if (!string.IsNullOrWhiteSpace(c.CurrentState)) { <span>@c.CurrentState</span> }
                    else { <span class="ac-sub">@(c.InWorld ? "In world" : "Not in world")</span> }
                    @if (!string.IsNullOrWhiteSpace(c.Target)) { <span class="ac-sub"> → @c.Target</span> }
                </div>

                <div class="ac-stream-bar">
                    <button class="ac-pill @(_streaming.Contains(c.Pid) ? "on" : "")" @onclick="@(() => ToggleStream(c.Pid))">
                        @(_streaming.Contains(c.Pid) ? "■ Stop stream" : "▶ Live view")
                    </button>
                </div>
                @if (_streaming.Contains(c.Pid))
                {
                    <div class="ac-stream">
                        @if (Presets[PresetFor(c.Pid)].Hd)
                        {
                            <video id="@VideoId(c.Pid)" autoplay playsinline muted></video>
                        }
                        else
                        {
                            <img src="@StreamSrc(c.Pid)" alt="live view of @c.DisplayName" />
                        }
                    </div>
                    <div class="ac-qsel">
                        @for (int i = 0; i < Presets.Length; i++)
                        {
                            int idx = i; int pid = c.Pid;
                            <button class="ac-pill @(PresetFor(pid) == idx ? "on" : "")" @onclick="@(() => SetPreset(pid, idx))">@Presets[idx].Label</button>
                        }
                        <span class="lbl" style="margin-left:auto">@DataRateText(c.Pid)</span>
                    </div>
                }

                @if (!string.Equals(c.Source, "heartbeat-log", StringComparison.OrdinalIgnoreCase))
                {
                    <div class="ac-stats">
                        @Stat("kills/hr", c.KillsPerHour.ToString("F0"))
                        @Stat("kills", c.SessionKills.ToString())
                        @Stat("last kill", Since(c.SecsSinceLastKill), StaleKill(c))
                        @Stat("xp/hr", FmtRate(c.XpPerHour))
                        @Stat("xp ses", FmtRate(c.XpSession))
                        @if (c.LuminancePerHour > 0) { @Stat("lum/hr", FmtRate(c.LuminancePerHour)) }
                        @Stat("vitae", c.VitaePct > 0 ? $"{c.VitaePct:F0}%" : "0")
                        @Stat("deaths", c.DeathsSession > 0 ? $"{c.DeathsSession}/{c.Deaths}" : c.Deaths.ToString())
                        @if (c.BurdenPct > 0) { @Stat("burden", $"{c.BurdenPct:F0}%", c.BurdenPct >= 100) }
                        @if (c.FreeSlots >= 0) { @Stat("slots", c.FreeSlots.ToString(), c.FreeSlots <= 2) }
                        @if (c.ScarabsByType is { Count: > 0 })
                        {
                            @foreach (var s in c.ScarabsByType)
                            {
                                @Stat(s.ShortLabel, s.Count.ToString(), s.Count <= 50)
                            }
                        }
                        else if (c.Scarabs >= 0) { @Stat("scarabs", c.Scarabs.ToString(), c.Scarabs <= 50) }
                        @if (c.Tapers >= 0) { @Stat("tapers", c.Tapers.ToString(), c.Tapers <= 50) }
                        @if (!string.IsNullOrWhiteSpace(c.Area)) { @Stat("area", c.Area!) }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(c.LastIssue))
                    {
                        <div class="ac-issue" title="most recent engine warning/error">
                            &#9888; @c.LastIssue@(c.LastIssueAgeSec >= 0 ? $" ({Since((int)c.LastIssueAgeSec)} ago)" : "")
                        </div>
                    }

                    @if (c.Equipment is { Count: > 0 })
                    {
                        <div class="ac-gear">
                            <button class="ac-gear-h" @onclick="@(() => ToggleGear(c.Pid))">
                                @(_showGear.Contains(c.Pid) ? "▾" : "▸") Gear (@c.Equipment.Count)
                            </button>
                            @if (_showGear.Contains(c.Pid))
                            {
                                <div class="ac-gear-list">
                                    @foreach (var it in c.Equipment)
                                    {
                                        <div>
                                            <div class="ac-gear-row" @onclick="@(() => ToggleItem(it.Id))" title="tap for appraisal">
                                                <span class="gn">@(it.HasAppraisal ? (_showItem.Contains(it.Id) ? "▾ " : "▸ ") : "")@it.Name</span>
                                                <span class="gi">@it.HexId</span>
                                            </div>
                                            @if (_showItem.Contains(it.Id) && it.HasAppraisal)
                                            {
                                                <div class="ac-appr">
                                                    @if (it.IsArmor)
                                                    {
                                                        <div><b>AL @it.ArmorLevel</b>@foreach (var r in it.NotableResists()){<span class="rb">@r.Label ×@r.Mod.ToString("0.00")</span>}</div>
                                                    }
                                                    @if (it.IsWeapon)
                                                    {
                                                        <div><b>Dmg @it.Damage</b> @it.DamageTypeName() · var ×@it.Variance.ToString("0.00")@(it.ElementalMod > 1 ? $" · elem +{(it.ElementalMod * 100 - 100):0}%" : "")</div>
                                                        <div>Def: melee @it.WeaponDef.ToString("0.00") · missile @it.MissileDef.ToString("0.00") · magic @it.MagicDef.ToString("0.00")</div>
                                                    }
                                                    <div class="amono">
                                                        @if (it.Workmanship > 0) { <span>wk @it.Workmanship</span> }
                                                        @if (it.Value > 0) { <span>@it.Value.ToString("N0") pyreal</span> }
                                                        @if (it.Burden > 0) { <span>bur @it.Burden</span> }
                                                        @if (it.MaxMana > 0) { <span>mana @it.CurMana/@it.MaxMana</span> }
                                                    </div>
                                                    @if (it.Spells is { Count: > 0 })
                                                    {
                                                        <div class="aspells">@foreach (var sp in it.Spells){<span class="sp">@sp</span>}</div>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(it.LongDesc))
                                                    {
                                                        <div class="adesc">@it.LongDesc</div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }

                    @if (_showControls)
                    {
                        <div class="ac-ctrl">
                            <button class="ac-pill ac-macro @(c.MacroRunning ? "on" : "")"
                                    @onclick="@(() => SendCommand(c, "macro", c.MacroRunning ? "false" : "true"))">
                                @(c.MacroRunning ? "■ Stop" : "▶ Start")
                            </button>
                            @foreach (var t in Toggles(c))
                            {
                                <button class="ac-pill @(t.On ? "on" : "")"
                                        @onclick="@(() => SendCommand(c, t.Action, t.On ? "false" : "true"))">@t.Label</button>
                            }
                        </div>
                        @if (c.NavProfiles is { Count: > 0 } || c.LootProfiles is { Count: > 0 } || c.MetaProfiles is { Count: > 0 })
                        {
                            <div class="ac-ctrl">
                                @if (c.NavProfiles is { Count: > 0 })
                                {
                                    <select class="ac-sel" title="nav profile" @onchange="@(e => CmdProfile(c, "navProfile", e))">
                                        @for (int i = 0; i < c.NavProfiles.Count; i++)
                                        { <option value="@i" selected="@(i == c.SelectedNavIdx)">@Trunc(c.NavProfiles[i])</option> }
                                    </select>
                                }
                                @if (c.LootProfiles is { Count: > 0 })
                                {
                                    <select class="ac-sel" title="loot profile" @onchange="@(e => CmdProfile(c, "lootProfile", e))">
                                        @for (int i = 0; i < c.LootProfiles.Count; i++)
                                        { <option value="@i" selected="@(i == c.SelectedLootIdx)">@Trunc(c.LootProfiles[i])</option> }
                                    </select>
                                }
                                @if (c.MetaProfiles is { Count: > 0 })
                                {
                                    <select class="ac-sel" title="meta profile" @onchange="@(e => CmdProfile(c, "metaProfile", e))">
                                        @for (int i = 0; i < c.MetaProfiles.Count; i++)
                                        { <option value="@i" selected="@(i == c.SelectedMetaIdx)">@Trunc(c.MetaProfiles[i])</option> }
                                    </select>
                                }
                            </div>
                        }
                        <div class="ac-ctrl">
                            <button class="ac-pill" @onclick="@(() => SendCommand(c, "clearBusy", "true"))">clear busy</button>
                            <button class="ac-pill" @onclick="@(() => SendCommand(c, "forceRebuff", "true"))">force rebuff</button>
                            <button class="ac-pill" @onclick="@(() => SendCommand(c, "cancelRebuff", "true"))">cancel</button>
                            <button class="ac-pill @(c.UiHidden ? "on" : "")" @onclick="@(() => SendCommand(c, "hideUi", c.UiHidden ? "false" : "true"))">@(c.UiHidden ? "Show UI" : "Hide UI")</button>
                            @if (_closePending.Contains(c.Pid))
                            {
                                <button class="ac-pill ac-danger" @onclick="@(() => ConfirmClose(c))">Confirm close?</button>
                            }
                            else
                            {
                                <button class="ac-pill" @onclick="@(() => ArmClose(c.Pid))">Close</button>
                            }
                        </div>
                        @if (_cmdMsg.TryGetValue(c.Pid, out var cm) && !string.IsNullOrEmpty(cm))
                        {
                            <div class="ac-cmd-msg">@cm</div>
                        }
                    }

                    <div class="ac-chat">
                        <button class="ac-gear-h" @onclick="@(() => ToggleChat(c.Pid))">
                            @(_showChat.Contains(c.Pid) ? "▾" : "▸") Chat@(c.RecentChat is { Count: > 0 } ? $" ({c.RecentChat.Count})" : "")
                        </button>
                        @if (_showChat.Contains(c.Pid))
                        {
                            <div class="ac-chat-log">
                                @if (c.RecentChat is { Count: > 0 })
                                {
                                    @for (int i = c.RecentChat.Count - 1; i >= 0; i--)
                                    {
                                        <div class="ac-chat-line" style="color:@c.RecentChat[i].Color">@c.RecentChat[i].Text</div>
                                    }
                                }
                                else { <div class="ac-sub">no chat captured yet</div> }
                            </div>
                            <div class="ac-chat-send">
                                <input class="ac-chat-input" placeholder="say, or /tell /f /command…"
                                       value="@GetDraft(c.Pid)"
                                       @oninput="@(e => _chatDraft[c.Pid] = e.Value?.ToString() ?? string.Empty)"
                                       @onkeydown="@(e => ChatKeyDown(e, c))" />
                                <button class="ac-pill" @onclick="@(() => SendChat(c))">Send</button>
                            </div>
                        }
                    </div>

                    <div class="ac-drive">
                        <button class="ac-gear-h" @onclick="@(() => ToggleDrive(c.Pid))">
                            @(_showDrive.Contains(c.Pid) ? "▾" : "▸") Drive
                        </button>
                        @if (_showDrive.Contains(c.Pid))
                        {
                            <div class="ac-dpad">
                                <span></span>
                                <div class="ac-dbtn @(Held(c.Pid, "forward"))"
                                     @onpointerdown="@(() => StartMove(c, "forward"))"
                                     @onpointerup="@(() => StopMove(c, "forward"))"
                                     @onpointerleave="@(() => StopMove(c, "forward"))"
                                     @onpointercancel="@(() => StopMove(c, "forward"))"
                                     @oncontextmenu:preventDefault>▲</div>
                                <span></span>
                                <div class="ac-dbtn @(Held(c.Pid, "left"))"
                                     @onpointerdown="@(() => StartMove(c, "left"))"
                                     @onpointerup="@(() => StopMove(c, "left"))"
                                     @onpointerleave="@(() => StopMove(c, "left"))"
                                     @onpointercancel="@(() => StopMove(c, "left"))"
                                     @oncontextmenu:preventDefault>◀</div>
                                <div class="ac-dbtn stop" @onclick="@(() => HardStop(c))">■</div>
                                <div class="ac-dbtn @(Held(c.Pid, "right"))"
                                     @onpointerdown="@(() => StartMove(c, "right"))"
                                     @onpointerup="@(() => StopMove(c, "right"))"
                                     @onpointerleave="@(() => StopMove(c, "right"))"
                                     @onpointercancel="@(() => StopMove(c, "right"))"
                                     @oncontextmenu:preventDefault>▶</div>
                                <span></span>
                                <div class="ac-dbtn @(Held(c.Pid, "back"))"
                                     @onpointerdown="@(() => StartMove(c, "back"))"
                                     @onpointerup="@(() => StopMove(c, "back"))"
                                     @onpointerleave="@(() => StopMove(c, "back"))"
                                     @onpointercancel="@(() => StopMove(c, "back"))"
                                     @oncontextmenu:preventDefault>▼</div>
                                <span></span>
                            </div>
                            <div class="ac-dnote">hold to move · ◀▶ turn · ■ stop @(c.MacroRunning ? "· stop the macro first — nav & combat facing will fight you" : "")</div>
                        }
                    </div>
                }

                <div class="ac-foot">
                    <span class="@(c.InWorld && c.Fps == 0 ? "ac-warn" : "")">@c.Fps fps</span>
                    <span class="@(c.MacroRunning && c.PluginTicksPerSec == 0 ? "ac-warn" : "")">@c.PluginTicksPerSec /s</span>
                    <span>up @Dur(c.UptimeSec)</span>
                    @if (c.AgeSec >= 12) { <span class="ac-warn">stale @c.AgeSec.ToString("F0")s</span> }
                    @if (string.Equals(c.Source, "heartbeat-log", StringComparison.OrdinalIgnoreCase)) { <span title="basic info only — status export off for this client">log-only</span> }
                </div>
            </div>
        }
    </div>
}

@code {
    private const string UrlKey = "ac.status.url";
    private const string TokenKey = "ac.status.token";

    private string _url = "";
    private string? _token;
    private string _urlEdit = "";
    private string _tokenEdit = "";
    private bool _showConfig;
    private bool _savedConfig;

    private AcStatusResult? _result;
    private CancellationTokenSource? _cts;
    private bool _disposed;

    private bool _showControls = true;
    private readonly Dictionary<int, string?> _cmdMsg = new();   // per-pid transient command feedback
    private readonly HashSet<int> _streaming = new();            // pids with a live MJPEG view open
    private readonly Dictionary<int, int> _presetByPid = new();  // per-client quality/fps preset
    private readonly Dictionary<int, int> _epochByPid = new();   // per-client reconnect token (resume / quality change)
    private readonly Dictionary<int, double> _frameKbByPid = new(); // measured frame size per client
    private int _defaultPreset = 1;                              // remembered, used for new streams
    private const string PresetKey = "ac.stream.preset";

    private sealed record StreamPreset(string Label, int Fps, int Q, int W, bool Hd = false);
    private static readonly StreamPreset[] Presets =
    {
        new("Saver", 2, 40, 480),     // ~tiny, for cellular (MJPEG)
        new("Balanced", 5, 50, 720),
        new("Smooth", 12, 60, 0),     // native size, full motion (Wi-Fi)
        new("HD ⚡", 0, 0, 0, Hd: true), // WebRTC H.264 — low latency, "play" mode (Wi-Fi)
    };

    private static string VideoId(int pid) => $"ac-hd-{pid}";
    private readonly HashSet<int> _hdActive = new();   // pids with a live WebRTC connection (JS-side)

    private int PresetFor(int pid) => _presetByPid.TryGetValue(pid, out int v) ? v : _defaultPreset;

    private string StreamSrc(int pid)
    {
        var p = Presets[PresetFor(pid)];
        int epoch = _epochByPid.TryGetValue(pid, out int e) ? e : 0;
        return AcStatusClient.BuildStreamUrl(_url, pid, _token, p.Fps, p.Q, p.W, epoch);
    }

    private async Task ToggleStream(int pid)
    {
        if (!_streaming.Add(pid)) { _streaming.Remove(pid); return; }
        await MeasureFrameAsync(pid);
    }

    private async Task SetPreset(int pid, int idx)
    {
        if (idx < 0 || idx >= Presets.Length || PresetFor(pid) == idx) return;
        _presetByPid[pid] = idx;
        _defaultPreset = idx;                                    // remember for the next stream you open
        _frameKbByPid.Remove(pid);
        _epochByPid[pid] = (_epochByPid.TryGetValue(pid, out int e) ? e : 0) + 1;  // reconnect just this stream
        try { await SettingsSvc.SetAsync(PresetKey, idx.ToString()); } catch { }
        StateHasChanged();
        await MeasureFrameAsync(pid);
    }

    private async Task MeasureFrameAsync(int pid)
    {
        if (Presets[PresetFor(pid)].Hd) return;       // HD = WebRTC, no MJPEG frame to measure
        var p = Presets[PresetFor(pid)];
        int bytes = await Status.MeasureFrameBytesAsync(_url, _token, pid, p.Q, p.W);
        if (bytes > 0) { _frameKbByPid[pid] = bytes / 1024.0; if (!_disposed) await InvokeAsync(StateHasChanged); }
    }

    private string DataRateText(int pid)
    {
        if (Presets[PresetFor(pid)].Hd) return "HD · WebRTC H.264";
        if (!_frameKbByPid.TryGetValue(pid, out double kb) || kb <= 0) return "measuring…";
        double kbs = kb * Presets[PresetFor(pid)].Fps;
        return $"~{kbs:F0} KB/s · ~{kbs * 3600 / 1024:F0} MB/hr";
    }

    // Sync the JS-side WebRTC connections to the rendered state. Runs after every render (the <video>
    // element exists by then). Idempotent — only starts/stops on a diff. Start is HD-preset + streaming;
    // stop is everything else. Reuses the existing _streaming / preset state, so it tracks Stop-stream,
    // preset switches (HD↔MJPEG), and cards leaving the feed automatically.
    private async Task ReconcileHd()
    {
        if (string.IsNullOrWhiteSpace(_url)) return;
        var livePids = _result?.Payload?.Clients?.Select(c => c.Pid).ToHashSet() ?? new HashSet<int>();
        // Start: streaming + HD preset + present in feed + not already active.
        foreach (int pid in _streaming.ToArray())
        {
            bool wantHd = Presets[PresetFor(pid)].Hd && livePids.Contains(pid);
            if (wantHd && _hdActive.Add(pid))
                try { await JS.InvokeVoidAsync("rynthHd.start", VideoId(pid), _url, _token, pid); } catch { _hdActive.Remove(pid); }
        }
        // Stop: any active pid that should no longer be HD-streaming.
        foreach (int pid in _hdActive.ToArray())
        {
            bool wantHd = _streaming.Contains(pid) && Presets[PresetFor(pid)].Hd && livePids.Contains(pid);
            if (!wantHd)
            {
                _hdActive.Remove(pid);
                try { await JS.InvokeVoidAsync("rynthHd.stop", pid, _url, _token); } catch { }
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_disposed) await ReconcileHd();
    }

    private void OnResumed()
    {
        if (_streaming.Count == 0) return;
        foreach (int pid in _streaming)                          // iOS dropped the streams — reconnect each
            _epochByPid[pid] = (_epochByPid.TryGetValue(pid, out int e) ? e : 0) + 1;
        // WebRTC connections die on background too: forget them so the next render's ReconcileHd re-offers
        // (JS start() closes the stale peer first). Faster than a full agent-side teardown/restart.
        _hdActive.Clear();
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnSuspended()
    {
        // App backgrounding: any held button won't get its pointer-up, so release every held pid now.
        // Best-effort — the POST may not flush before iOS freezes us, which is exactly why the plugin
        // dead-man's switch (fed by the keepalive) is the real guarantee. Send by pid, no _result
        // lookup, so this is safe to run off the renderer thread (the iOS lifecycle thread).
        int[] pids;
        lock (_moveLock)
        {
            if (_held.Count == 0) return;
            pids = _held.Keys.ToArray();
            _held.Clear();
        }
        foreach (var pid in pids) SendMove(pid, "stop", false);
    }

    private readonly HashSet<int> _closePending = new();         // pids armed for a confirm-close
    private async Task ArmClose(int pid)
    {
        _closePending.Add(pid);
        StateHasChanged();
        try { await Task.Delay(4000); } catch { }
        if (_closePending.Remove(pid) && !_disposed) await InvokeAsync(StateHasChanged);
    }
    private async Task ConfirmClose(AcClientStatus c)
    {
        _closePending.Remove(c.Pid);
        await SendCommand(c, "closeClient", "true");
    }

    private readonly HashSet<int> _showGear = new();             // pids whose gear list is expanded
    private void ToggleGear(int pid) { if (!_showGear.Add(pid)) _showGear.Remove(pid); }
    private readonly HashSet<uint> _showItem = new();            // item ids whose appraisal is expanded
    private void ToggleItem(uint id) { if (!_showItem.Add(id)) _showItem.Remove(id); }

    private readonly HashSet<int> _showChat = new();             // pids whose chat panel is open
    private void ToggleChat(int pid) { if (!_showChat.Add(pid)) _showChat.Remove(pid); }
    private readonly Dictionary<int, string> _chatDraft = new();
    private string GetDraft(int pid) => _chatDraft.TryGetValue(pid, out var v) ? v : "";
    private async Task ChatKeyDown(KeyboardEventArgs e, AcClientStatus c) { if (e.Key == "Enter") await SendChat(c); }
    private async Task SendChat(AcClientStatus c)
    {
        string text = GetDraft(c.Pid);
        if (string.IsNullOrWhiteSpace(text)) return;
        _chatDraft[c.Pid] = string.Empty;
        StateHasChanged();
        await SendCommand(c, "sendChat", text);
    }

    // ── Movement d-pad (hold-to-move) ────────────────────────────────────────
    private readonly HashSet<int> _showDrive = new();            // pids whose d-pad is open
    private void ToggleDrive(int pid) { if (!_showDrive.Add(pid)) _showDrive.Remove(pid); }
    // pid → the SET of directions currently held. A set (not one slot) so you can run AND steer at the
    // same time, with each held direction independently kept alive + released. _moveLock guards _held /
    // _moveChain because the keepalive timer thread touches them alongside the renderer thread.
    private readonly Dictionary<int, HashSet<string>> _held = new();
    private readonly object _moveLock = new();
    private string Held(int pid, string dir)
    {
        lock (_moveLock) return _held.TryGetValue(pid, out var s) && s.Contains(dir) ? "held" : "";
    }

    private void StartMove(AcClientStatus c, string dir)
    {
        lock (_moveLock)
        {
            if (!_held.TryGetValue(c.Pid, out var s)) _held[c.Pid] = s = new();
            s.Add(dir);
        }
        SendMove(c.Pid, dir, true);
    }

    private void StopMove(AcClientStatus c, string dir)
    {
        bool nowEmpty = false;
        lock (_moveLock)
            if (_held.TryGetValue(c.Pid, out var s) && s.Remove(dir) && s.Count == 0) { _held.Remove(c.Pid); nowEmpty = true; }
        // Releasing the LAST held direction → send a full "stop": it releases everything AND disarms the
        // plugin dead-man immediately, so the watchdog can't fire a delayed stop later that would clobber
        // the bot if it re-took control. A non-last release just drops that one direction (others keep going).
        SendMove(c.Pid, nowEmpty ? "stop" : dir, false);
    }

    private void HardStop(AcClientStatus c)
    {
        lock (_moveLock) _held.Remove(c.Pid);
        SendMove(c.Pid, "stop", false);
    }

    // Keepalive: while a direction is held we re-assert EACH held direction on a heartbeat so the
    // plugin's dead-man's switch stays fed. If anything cuts a held button off without a release
    // (pointercancel, app force-kill, Wi-Fi drop, page nav, card unmount), the heartbeat stops and the
    // plugin auto-stops shortly after. This is the real runaway backstop — a single release POST can
    // always be lost. Sends are coalesced (see SendMove) so a stalled POST can't starve the heartbeat.
    private const int KeepAliveMs = 300;
    private async Task KeepAliveLoopAsync(CancellationToken ct)
    {
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromMilliseconds(KeepAliveMs));
            while (await timer.WaitForNextTickAsync(ct))
            {
                (int pid, string dir)[] held;
                lock (_moveLock)
                {
                    if (_held.Count == 0) continue;
                    held = _held.SelectMany(kv => kv.Value.Select(d => (kv.Key, d))).ToArray();
                }
                foreach (var (pid, dir) in held)
                    SendMove(pid, dir, true, coalesce: true);   // skipped if a send for this pid is still in flight
            }
        }
        catch (OperationCanceledException) { /* disposed */ }
    }

    // Sends serialize PER PID so a release can't be overtaken by a stale keepalive (the agent stamps on
    // receipt and the plugin applies in that order). But they must NOT back-pressure: a stalled POST
    // can't be allowed to stack keepalives behind it — that starves the plugin watchdog (→ false stop),
    // then the queued burst flushes and *resumes* motion you released. So every send has a SHORT timeout
    // (well under the dead-man window) and keepalives COALESCE: a keepalive is dropped while this pid
    // still has a send in flight (the next tick retries). Explicit press/release always go through.
    private const int MoveSendTimeoutMs = 1000;
    private readonly Dictionary<int, Task> _moveChain = new();
    private void SendMove(int pid, string dir, bool start, bool coalesce = false)
    {
        lock (_moveLock)
        {
            if (coalesce && _moveChain.TryGetValue(pid, out var cur) && !cur.IsCompleted) return;
            Task prev = _moveChain.TryGetValue(pid, out var t) ? t : Task.CompletedTask;
            _moveChain[pid] = ChainSend(prev, pid, start ? "moveStart" : "moveStop", dir);
        }
    }

    private async Task ChainSend(Task prev, int pid, string action, string dir)
    {
        try { await prev; } catch { /* prior send never throws, but stay defensive */ }
        using var cts = new CancellationTokenSource(MoveSendTimeoutMs);   // bound a stalled POST well under the watchdog
        await Status.PostCommandAsync(_url, _token, pid, action, dir, cts.Token);
    }

    // A pid can leave the feed (box relaunched → new pid, or dropped on a transient agent error) while
    // a button is held. The held element is unmounted with no pointer-up, so without this the keepalive
    // loop would keep feeding the watchdog and sustain the very runaway it guards against. Release +
    // forget any held/queued pid no longer present, so the heartbeat stops and the plugin can self-stop.
    private void ReconcileHeldWithFeed()
    {
        var live = _result?.Payload?.Clients;
        if (live is null) return;
        int[] goneHeld;
        lock (_moveLock)
        {
            goneHeld = _held.Keys.Where(pid => !live.Any(x => x.Pid == pid)).ToArray();
            foreach (var pid in goneHeld) _held.Remove(pid);
            foreach (var pid in _moveChain.Keys.ToArray())      // prune completed chains for gone pids
                if (!_held.ContainsKey(pid) && !live.Any(x => x.Pid == pid)) _moveChain.Remove(pid);
        }
        foreach (var pid in goneHeld) SendMove(pid, "stop", false);
    }

    protected override async Task OnInitializedAsync()
    {
        _url = await SettingsSvc.GetAsync(UrlKey, "");
        _token = await SettingsSvc.GetAsync(TokenKey);
        _urlEdit = _url;
        _tokenEdit = _token ?? "";
        if (int.TryParse(await SettingsSvc.GetAsync(PresetKey, "1"), out int pi))
            _defaultPreset = Math.Clamp(pi, 0, Presets.Length - 1);
        StreamLifecycle.Resumed += OnResumed;
        StreamLifecycle.Suspended += OnSuspended;
        _cts = new CancellationTokenSource();
        _ = PollLoopAsync(_cts.Token);
        _ = KeepAliveLoopAsync(_cts.Token);
    }

    private async Task PollLoopAsync(CancellationToken ct)
    {
        await RefreshOnceAsync(ct);
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(4));
            while (await timer.WaitForNextTickAsync(ct))
                await RefreshOnceAsync(ct);
        }
        catch (OperationCanceledException) { /* disposed */ }
    }

    private async Task RefreshOnceAsync(CancellationToken ct)
    {
        if (string.IsNullOrWhiteSpace(_url)) return;
        var requestedUrl = _url;   // so a response that lands after a config change is discarded
        try
        {
            var r = await Status.GetStatusAsync(_url, _token, ct);
            // Bail if the page is gone, the poll was cancelled, or the URL changed mid-flight
            // (a stale old-host response must not overwrite the freshly-switched view).
            if (_disposed || ct.IsCancellationRequested
                || !string.Equals(requestedUrl, _url, StringComparison.Ordinal)) return;
            _result = r;
            if (_held.Count > 0) ReconcileHeldWithFeed();   // release any held pid that just left the feed
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException) { /* cancelled (page disposed / config change) */ }
        catch (ObjectDisposedException) { /* circuit/renderer torn down mid-render */ }
    }

    private Task Refresh() => RefreshOnceAsync(_cts?.Token ?? CancellationToken.None);

    private void ToggleConfig() => _showConfig = !_showConfig;

    private async Task SaveConfig()
    {
        _url = _urlEdit?.Trim() ?? "";
        _token = string.IsNullOrWhiteSpace(_tokenEdit) ? null : _tokenEdit.Trim();
        await SettingsSvc.SetAsync(UrlKey, _url);
        await SettingsSvc.SetAsync(TokenKey, _token ?? "");
        _savedConfig = true;
        _showConfig = false;
        _result = null;
        await RefreshOnceAsync(_cts?.Token ?? CancellationToken.None);
    }

    private static RenderFragment Bar(string label, uint cur, uint max, string color) => __builder =>
    {
        int pct = max > 0 ? (int)Math.Clamp(Math.Round(cur * 100.0 / max), 0, 100) : 0;
        <div class="ac-vlabel"><span>@label</span><span>@cur/@max</span></div>
        <div class="ac-bar"><span style="width:@pct%;background:@color"></span></div>
    };

    private static RenderFragment Stat(string label, string value, bool warn = false) => __builder =>
    {
        <div class="ac-stat"><div class="sv@(warn ? " warn" : "")">@value</div><div class="sl">@label</div></div>
    };

    // ── Remote control ──────────────────────────────────────────────────────
    private static IEnumerable<(string Action, string Label, bool On)> Toggles(AcClientStatus c) =>
        new[]
        {
            ("navigation", "Nav", c.NavigationEnabled),
            ("combat", "Combat", c.CombatEnabled),
            ("buffing", "Buff", c.BuffingEnabled),
            ("looting", "Loot", c.LootingEnabled),
            ("meta", "Meta", c.MetaEnabled),
        };

    private static string Trunc(string s) => string.IsNullOrEmpty(s) ? s : (s.Length <= 14 ? s : s[..13] + "…");

    private async Task CmdProfile(AcClientStatus c, string action, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int idx))
            await SendCommand(c, action, idx.ToString());
    }

    private async Task SendCommand(AcClientStatus c, string action, string value)
    {
        _cmdMsg[c.Pid] = "sending…";
        StateHasChanged();
        var r = await Status.PostCommandAsync(_url, _token, c.Pid, action, value);
        _cmdMsg[c.Pid] = r.Ok ? "✓ sent" : ("✗ " + r.Error);
        StateHasChanged();
        if (r.Ok)
        {
            // Give the box ~1.2s to poll, apply, and rewrite its status file, then refresh so the
            // switch positions reflect reality (the feed is the source of truth, not optimistic local state).
            try { await Task.Delay(1200, _cts?.Token ?? CancellationToken.None); } catch { }
            if (!_disposed) await RefreshOnceAsync(_cts?.Token ?? CancellationToken.None);
        }
        _ = ClearMsgLater(c.Pid);
    }

    private async Task ClearMsgLater(int pid)
    {
        try { await Task.Delay(3000); } catch { }
        if (_disposed) return;
        _cmdMsg.Remove(pid);
        await InvokeAsync(StateHasChanged);
    }

    // Compact rate: 1.2M / 450k / 87.
    private static string FmtRate(double v)
    {
        if (v >= 1_000_000) return (v / 1_000_000).ToString("0.0") + "M";
        if (v >= 1_000) return (v / 1_000).ToString("0.0") + "k";
        return v.ToString("F0");
    }

    // Compact elapsed: "—" (none) / "12s" / "4m" / "2h".
    private static string Since(int seconds)
    {
        if (seconds < 0) return "—";
        if (seconds < 60) return $"{seconds}s";
        if (seconds < 3600) return $"{seconds / 60}m";
        return $"{seconds / 3600}h";
    }

    // Highlight "last kill" when a botting client hasn't killed anything in a while —
    // the clearest "is it stuck?" signal. Only meaningful once combat is enabled.
    private static bool StaleKill(AcClientStatus c)
        => c.SecsSinceLastKill >= 180
           && string.Equals(c.State, "botting", StringComparison.OrdinalIgnoreCase);

    private static string StateColor(string state) => state switch
    {
        "botting"           => "#34d399",
        "idle" or "running" => "#60a5fa",
        "loading"           => "#fbbf24",
        "wedged" or "hung" or "dead" => "#f87171",
        _ => "#94a3b8",
    };

    private static string Dur(long seconds)
    {
        var t = TimeSpan.FromSeconds(seconds);
        return t.TotalHours >= 1 ? $"{(int)t.TotalHours}h{t.Minutes:D2}m" : $"{t.Minutes}m";
    }

    private static string Ago(DateTimeOffset? ts)
    {
        if (ts is null) return "—";
        var s = (DateTimeOffset.UtcNow - ts.Value).TotalSeconds;
        return s < 0 ? "now" : s < 60 ? $"{(int)s}s ago" : $"{(int)(s / 60)}m ago";
    }

    public ValueTask DisposeAsync()
    {
        _disposed = true;
        // Page being torn down (nav away / back) while a button is held fires no pointer-up — release
        // every held pid before we cancel the loops. Fire-and-forget; the plugin dead-man backstops it.
        int[] pids;
        lock (_moveLock) { pids = _held.Keys.ToArray(); _held.Clear(); }
        foreach (var pid in pids) SendMove(pid, "stop", false);
        // Tear down any HD WebRTC streams (close the peer + tell the agent to stop encoding). Fire-and-forget.
        foreach (var pid in _hdActive.ToArray())
            try { _ = JS.InvokeVoidAsync("rynthHd.stop", pid, _url, _token); } catch { }
        _hdActive.Clear();
        StreamLifecycle.Resumed -= OnResumed;
        StreamLifecycle.Suspended -= OnSuspended;
        _cts?.Cancel();
        _cts?.Dispose();
        _cts = null;
        return ValueTask.CompletedTask;
    }
}
