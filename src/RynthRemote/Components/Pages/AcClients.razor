        // Best-effort — the POST may not flush before iOS freezes us, which is exactly why the plugin
        // dead-man's switch (fed by the keepalive) is the real guarantee. Send by pid, no _result
        // lookup, so this is safe to run off the renderer thread (the iOS lifecycle thread).
        int[] pids;
        lock (_moveLock)
        {
            if (_held.Count == 0) return;
            pids = _held.Keys.ToArray();
            _held.Clear();
        }
        foreach (var pid in pids) SendMove(pid, "stop", false);
    }

    // Close-confirm countdown modal (replaces the old 2-tap arm→confirm). A destructive action must
    // never fire on a walked-away dialog, so the countdown AUTO-CANCELS at 0 — it never auto-closes.
    private int _closeModalPid;                 // pid whose modal is open (0 = none)
    private int _closeCountdown;                // seconds remaining
    private CancellationTokenSource? _closeCts;

    private void OpenCloseModal(int pid)
    {
