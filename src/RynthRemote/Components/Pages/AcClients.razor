@page "/"
@page "/clients"
@using RynthRemote.AcStatus
@inject IAcStatusClient Status
@inject SettingsStore SettingsSvc
@inject IJSRuntime JS
@inject IHdVideoController HdController
@implements IAsyncDisposable

<PageTitle>AC Clients - MicroManager</PageTitle>

<style>
    .ac-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(250px,1fr)); gap:.75rem; }
    .ac-card { border:1px solid var(--border); border-radius:10px; padding:.7rem .8rem; background:var(--surface); }
    .ac-card.bad { border-color:var(--red); }
    .ac-head { display:flex; align-items:center; justify-content:space-between; gap:.5rem; }
    .ac-name { font-weight:700; }
    .ac-sub { color:var(--muted); font-size:.78rem; }
    .ac-badge { font-size:.7rem; font-weight:700; text-transform:uppercase; letter-spacing:.04em; padding:.15rem .45rem; border-radius:999px; color:#0b1120; }
    .ac-bar { height:12px; border-radius:6px; background:var(--surface-2); overflow:hidden; margin:.15rem 0; }
    .ac-bar > span { display:block; height:100%; }
    .ac-vlabel { display:flex; justify-content:space-between; font-size:.7rem; color:var(--muted); }
    .ac-doing { margin:.5rem 0 .25rem; font-size:.85rem; }
    .ac-stream-bar { margin:.35rem 0 .25rem; }
    .ac-stream { margin:.25rem 0 .45rem; border:1px solid var(--border); border-radius:8px; overflow:hidden; background:#000; aspect-ratio:16/10; }
    .ac-stream img, .ac-stream video { width:100%; height:100%; object-fit:contain; display:block; background:#000; }
    .ac-hd-ph { width:100%; height:100%; display:flex; align-items:center; justify-content:center; color:#5b6b86; font-size:.8rem; }
    .ac-qsel { display:flex; gap:.3rem; align-items:center; flex-wrap:wrap; margin:.2rem 0 .6rem; padding:.4rem .5rem; background:var(--surface); border:1px solid var(--border); border-radius:8px; }
    .ac-qsel .lbl { font-size:.72rem; color:var(--muted); }
    .ac-stats { display:grid; grid-template-columns:repeat(auto-fit,minmax(56px,1fr)); gap:.3rem; margin:.4rem 0 .25rem; }
    .ac-stat { background:var(--surface-2); border-radius:6px; padding:.25rem .2rem; text-align:center; }
    .ac-stat .sv { font-weight:700; font-size:.9rem; font-variant-numeric:tabular-nums; line-height:1.1; }
    .ac-stat .sv.warn { color:var(--amber); }
    .ac-stat .sl { font-size:.6rem; color:var(--muted); text-transform:uppercase; letter-spacing:.03em; }
    .ac-foot { display:flex; flex-wrap:wrap; gap:.5rem .9rem; font-size:.72rem; color:var(--muted); margin-top:.4rem; }
    .ac-issue { font-size:.72rem; color:var(--amber); margin-top:.35rem; word-break:break-word; }
    .ac-warn { color:var(--amber); }
    .ac-ctrl { display:flex; flex-wrap:wrap; gap:.3rem; margin-top:.45rem; align-items:center; }
    .ac-pill { font-size:.8rem; padding:.5rem .8rem; border-radius:999px; border:1px solid var(--border); background:var(--surface-2); color:inherit; cursor:pointer; }
    .ac-pill:disabled { opacity:.5; cursor:default; }
    .ac-pill.on { background:#34d399; color:#06281c; border-color:transparent; font-weight:700; }
    .ac-pill.ac-macro.on { background:#f87171; color:#3a0b0b; }
    .ac-sel { font-size:.8rem; padding:.45rem .5rem; border-radius:6px; border:1px solid var(--border); background:var(--surface-2); color:inherit; flex:1 1 30%; min-width:0; }
    .ac-cmd-msg { font-size:.7rem; color:var(--muted); margin-top:.25rem; }
    .ac-pill.ac-danger { background:#f87171; color:#3a0b0b; border-color:transparent; font-weight:700; }
    .ac-gear { margin-top:.4rem; }
    .ac-gear-h { font-size:.74rem; background:none; border:none; color:var(--muted); cursor:pointer; padding:.1rem 0; }
    .ac-gear-list { display:flex; flex-direction:column; gap:.12rem; margin-top:.2rem; }
    .ac-gear-row { display:flex; justify-content:space-between; gap:.5rem; font-size:.72rem; }
    .ac-gear-row { cursor:pointer; }
    .ac-gear-row .gn { overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .ac-gear-row .gi { color:var(--muted); font-family:ui-monospace,monospace; user-select:all; white-space:nowrap; }
    .ac-chat { margin-top:.4rem; }
    .ac-ctabs { display:flex; flex-wrap:wrap; gap:.25rem; margin:.2rem 0 .1rem; }
    .ac-ctab { font-size:.78rem; padding:.35rem .55rem; }
    .ac-chat-log { max-height:200px; overflow-y:auto; background:var(--bg); border:1px solid var(--border); border-radius:6px; padding:.35rem .45rem; display:flex; flex-direction:column; gap:.1rem; margin:.2rem 0; }
    .ac-chat-line { font-size:.74rem; line-height:1.25; word-break:break-word; }
    .ac-chat-send { display:flex; gap:.3rem; }
    .ac-chat-input { flex:1; min-width:0; background:var(--surface-2); border:1px solid var(--border); border-radius:6px; color:inherit; padding:.5rem .55rem; font-size:.9rem; }
    .ac-drive { margin-top:.4rem; }
    .ac-dpad { display:grid; grid-template-columns:repeat(3,1fr); grid-template-rows:repeat(3,1fr); gap:.35rem; max-width:230px; margin:.3rem auto .1rem; touch-action:none; }
    .ac-dbtn { display:flex; align-items:center; justify-content:center; aspect-ratio:1; font-size:1.5rem; line-height:1; background:var(--surface-2); border:1px solid var(--border); border-radius:10px; color:inherit; user-select:none; -webkit-user-select:none; -webkit-tap-highlight-color:transparent; cursor:pointer; }
    .ac-dbtn:active, .ac-dbtn.held { background:var(--accent); border-color:var(--accent); color:#0b1220; }
    .ac-dbtn.stop { font-size:1.05rem; color:var(--amber); }
    .ac-dnote { font-size:.7rem; color:var(--muted); text-align:center; }
    .ac-appr { font-size:.7rem; margin:.15rem 0 .35rem .6rem; padding-left:.5rem; border-left:2px solid var(--border); display:flex; flex-direction:column; gap:.15rem; }
    .ac-appr b { font-weight:700; }
    .ac-appr .rb { color:var(--amber); margin-left:.4rem; }
    .ac-appr .amono { color:var(--muted); display:flex; flex-wrap:wrap; gap:.5rem; }
    .ac-appr .aspells { display:flex; flex-wrap:wrap; gap:.25rem; }
    .ac-appr .aspells .sp { background:var(--surface-2); border-radius:4px; padding:.05rem .35rem; }
    .ac-appr .adesc { color:var(--muted); font-style:italic; }
</style>

<div class="card-head">
    <h1>&#127918; AC Clients</h1>
    <div class="flex" style="gap:.5rem">
        <button class="btn-r ghost sm" @onclick="() => _showControls = !_showControls">@(_showControls ? "Hide controls" : "Controls")</button>
        <button class="btn-r ghost sm" @onclick="ToggleConfig">@(_showConfig ? "Close" : "Connection")</button>
        <button class="btn-r ghost sm" @onclick="Refresh" disabled="@string.IsNullOrWhiteSpace(_url)">Refresh</button>
    </div>
</div>

@if (_showConfig || string.IsNullOrWhiteSpace(_url))
{
    <div class="card-r mb">
        <h3 style="margin-top:0">RynthCore StatusAgent</h3>
        <p class="muted" style="font-size:.82rem;margin-top:0">
            URL of your StatusAgent's pull endpoint, e.g. <code>http://your-pc:8740/status</code>
            (over Tailscale/LAN). Leave the token blank unless you set <code>ServeToken</code>.
        </p>
        <div class="field">
            <label>Status URL</label>
            <input @bind="_urlEdit" placeholder="http://your-pc:8740/status" />
        </div>
        <div class="field">
            <label>Token (optional)</label>
            <input @bind="_tokenEdit" placeholder="bearer token, if any" />
        </div>
        <div class="flex" style="gap:.5rem;margin-top:.5rem">
            <button class="btn-r" @onclick="SaveConfig">Save</button>
            @if (_savedConfig) { <span class="badge-r green">saved</span> }
        </div>
    </div>
}

@if (string.IsNullOrWhiteSpace(_url))
{
    <div class="card-r"><p class="muted">Set your StatusAgent URL above to see your AC clients.</p></div>
}
else if (_result is null)
{
    <p class="loading">Connecting to @_url …</p>
}
else if (!_result.Ok)
{
    <div class="card-r">
        <p class="ac-warn" style="margin-top:0">&#9888; @_result.Error</p>
        <p class="ac-sub">@_url — retrying every few seconds.</p>
    </div>
}
else
{
    var clients = _result.Payload!.Clients;
    var bad = clients.Count(c => !c.Healthy);

    <div class="card-r mb" style="border-left:4px solid @(bad > 0 ? "var(--red)" : "var(--green)")">
        <strong>@(clients.Count == 0 ? "No clients running"
                  : bad == 0 ? $"All {clients.Count} healthy"
                  : $"{bad} of {clients.Count} need attention")</strong>
        <span class="ac-sub" style="margin-left:.5rem">
            @_result.Payload.Host · updated @Ago(_result.Payload.GeneratedAtUtc)
        </span>
    </div>

    <div class="ac-grid">
        @foreach (var c in clients.OrderByDescending(c => !c.Healthy).ThenBy(c => c.Character))
        {
            <div class="ac-card @(c.Healthy ? "" : "bad")" @key="c.Pid">
                <div class="ac-head">
                    <div>
                        <div class="ac-name">@c.DisplayName</div>
                        <div class="ac-sub">@c.Server</div>
                    </div>
                    <span class="ac-badge" style="background:@StateColor(c.State)">@c.State</span>
                </div>

                @if (c.Player is { } v && v.MaxHp > 0)
                {
                    @Bar("HP", v.Hp, v.MaxHp, "#ef4444")
                    @Bar("Stam", v.St, v.MaxSt, "#22c55e")
                    @Bar("Mana", v.Mn, v.MaxMn, "#3b82f6")
                }

                <div class="ac-doing">
                    @if (!string.IsNullOrWhiteSpace(c.BotAction)) { <span>@c.BotAction</span> }
                    else if (!string.IsNullOrWhiteSpace(c.CurrentState)) { <span>@c.CurrentState</span> }
                    else { <span class="ac-sub">@(c.InWorld ? "In world" : "Not in world")</span> }
                    @if (!string.IsNullOrWhiteSpace(c.Target)) { <span class="ac-sub"> → @c.Target</span> }
                </div>

                <div class="ac-stream-bar">
                    <button class="ac-pill @(_streaming.Contains(c.Pid) ? "on" : "")" @onclick="@(() => ToggleStream(c.Pid))">
                        @(_streaming.Contains(c.Pid) ? "■ Stop stream" : "▶ Live view")
                    </button>
                </div>
                @if (_streaming.Contains(c.Pid))
                {
                    @if (Presets[PresetFor(c.Pid)].Hd)
                    {
                        <div id="@HdSlotId(c.Pid)" class="ac-stream"><div class="ac-hd-ph">📺 HD live — tap to enlarge</div></div>
                    }
                    else
                    {
                        <div class="ac-stream"><img src="@StreamSrc(c.Pid)" alt="live view of @c.DisplayName" /></div>
                    }
                    <div class="ac-qsel">
                        @for (int i = 0; i < Presets.Length; i++)
                        {
                            int idx = i; int pid = c.Pid;
                            <button class="ac-pill @(PresetFor(pid) == idx ? "on" : "")" @onclick="@(() => SetPreset(pid, idx))">@Presets[idx].Label</button>
                        }
                        <span class="lbl" style="margin-left:auto">@DataRateText(c.Pid)</span>
                    </div>
                }

                <div class="ac-drive">
                    <button class="ac-gear-h" @onclick="@(() => ToggleDrive(c.Pid))">
                        @(_showDrive.Contains(c.Pid) ? "▾" : "▸") Drive
                    </button>
                    @if (_showDrive.Contains(c.Pid))
                    {
                        <div class="ac-dpad">
                            <span></span>
                            <div class="ac-dbtn @(Held(c.Pid, "forward"))"
                                 @onpointerdown="@(() => StartMove(c, "forward"))"
                                 @onpointerup="@(() => StopMove(c, "forward"))"
                                 @onpointerleave="@(() => StopMove(c, "forward"))"
                                 @onpointercancel="@(() => StopMove(c, "forward"))"
                                 @oncontextmenu:preventDefault>▲</div>
                            <span></span>
                            <div class="ac-dbtn @(Held(c.Pid, "left"))"
                                 @onpointerdown="@(() => StartMove(c, "left"))"
                                 @onpointerup="@(() => StopMove(c, "left"))"
                                 @onpointerleave="@(() => StopMove(c, "left"))"
                                 @onpointercancel="@(() => StopMove(c, "left"))"
                                 @oncontextmenu:preventDefault>◀</div>
                            <div class="ac-dbtn stop" @onclick="@(() => HardStop(c))">■</div>
                            <div class="ac-dbtn @(Held(c.Pid, "right"))"
                                 @onpointerdown="@(() => StartMove(c, "right"))"
                                 @onpointerup="@(() => StopMove(c, "right"))"
                                 @onpointerleave="@(() => StopMove(c, "right"))"
                                 @onpointercancel="@(() => StopMove(c, "right"))"
                                 @oncontextmenu:preventDefault>▶</div>
                            <span></span>
                            <div class="ac-dbtn @(Held(c.Pid, "back"))"
                                 @onpointerdown="@(() => StartMove(c, "back"))"
                                 @onpointerup="@(() => StopMove(c, "back"))"
                                 @onpointerleave="@(() => StopMove(c, "back"))"
                                 @onpointercancel="@(() => StopMove(c, "back"))"
                                 @oncontextmenu:preventDefault>▼</div>
                            <span></span>
                        </div>
                        <div class="ac-dnote">hold to move · ◀▶ turn · ■ stop @(c.MacroRunning ? "· stop the macro first — nav & combat facing will fight you" : "")</div>
                    }
                </div>

                @if (!string.Equals(c.Source, "heartbeat-log", StringComparison.OrdinalIgnoreCase))
                {
                    <div class="ac-stats">
                        @Stat("kills/hr", c.KillsPerHour.ToString("F0"))
                        @Stat("kills", c.SessionKills.ToString())
                        @Stat("last kill", Since(c.SecsSinceLastKill), StaleKill(c))
                        @Stat("xp/hr", FmtRate(c.XpPerHour))
                        @Stat("xp ses", FmtRate(c.XpSession))
                        @if (c.LuminancePerHour > 0) { @Stat("lum/hr", FmtRate(c.LuminancePerHour)) }
                        @Stat("vitae", c.VitaePct > 0 ? $"{c.VitaePct:F0}%" : "0")
                        @Stat("deaths", c.DeathsSession > 0 ? $"{c.DeathsSession}/{c.Deaths}" : c.Deaths.ToString())
                        @if (c.BurdenPct > 0) { @Stat("burden", $"{c.BurdenPct:F0}%", c.BurdenPct >= 100) }
                        @if (c.FreeSlots >= 0) { @Stat("slots", c.FreeSlots.ToString(), c.FreeSlots <= 2) }
                        @if (c.ScarabsByType is { Count: > 0 })
                        {
                            @foreach (var s in c.ScarabsByType)
                            {
                                @Stat(s.ShortLabel, s.Count.ToString(), s.Count <= 50)
                            }
                        }
                        else if (c.Scarabs >= 0) { @Stat("scarabs", c.Scarabs.ToString(), c.Scarabs <= 50) }
                        @if (c.Tapers >= 0) { @Stat("tapers", c.Tapers.ToString(), c.Tapers <= 50) }
                        @if (!string.IsNullOrWhiteSpace(c.Area)) { @Stat("area", c.Area!) }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(c.LastIssue))
                    {
                        <div class="ac-issue" title="most recent engine warning/error">
                            &#9888; @c.LastIssue@(c.LastIssueAgeSec >= 0 ? $" ({Since((int)c.LastIssueAgeSec)} ago)" : "")
                        </div>
                    }

                    @if (c.Equipment is { Count: > 0 })
                    {
                        <div class="ac-gear">
                            <button class="ac-gear-h" @onclick="@(() => ToggleGear(c.Pid))">
                                @(_showGear.Contains(c.Pid) ? "▾" : "▸") Gear (@c.Equipment.Count)
                            </button>
                            @if (_showGear.Contains(c.Pid))
                            {
                                <div class="ac-gear-list">
                                    @foreach (var it in c.Equipment)
                                    {
                                        <div>
                                            <div class="ac-gear-row" @onclick="@(() => ToggleItem(it.Id))" title="tap for appraisal">
                                                <span class="gn">@(it.HasAppraisal ? (_showItem.Contains(it.Id) ? "▾ " : "▸ ") : "")@it.Name</span>
                                                <span class="gi">@it.HexId</span>
                                            </div>
                                            @if (_showItem.Contains(it.Id) && it.HasAppraisal)
                                            {
                                                <div class="ac-appr">
                                                    @if (it.IsArmor)
                                                    {
                                                        <div><b>AL @it.ArmorLevel</b>@foreach (var r in it.NotableResists()){<span class="rb">@r.Label ×@r.Mod.ToString("0.00")</span>}</div>
                                                    }
                                                    @if (it.IsWeapon)
                                                    {
                                                        <div><b>Dmg @it.Damage</b> @it.DamageTypeName() · var ×@it.Variance.ToString("0.00")@(it.ElementalMod > 1 ? $" · elem +{(it.ElementalMod * 100 - 100):0}%" : "")</div>
                                                        <div>Def: melee @it.WeaponDef.ToString("0.00") · missile @it.MissileDef.ToString("0.00") · magic @it.MagicDef.ToString("0.00")</div>
                                                    }
                                                    <div class="amono">
                                                        @if (it.Workmanship > 0) { <span>wk @it.Workmanship</span> }
                                                        @if (it.Value > 0) { <span>@it.Value.ToString("N0") pyreal</span> }
                                                        @if (it.Burden > 0) { <span>bur @it.Burden</span> }
                                                        @if (it.MaxMana > 0) { <span>mana @it.CurMana/@it.MaxMana</span> }
                                                    </div>
                                                    @if (it.Spells is { Count: > 0 })
                                                    {
                                                        <div class="aspells">@foreach (var sp in it.Spells){<span class="sp">@sp</span>}</div>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(it.LongDesc))
                                                    {
                                                        <div class="adesc">@it.LongDesc</div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }

                    @if (_showControls)
                    {
                        <div class="ac-ctrl">
                            <button class="ac-pill ac-macro @(c.MacroRunning ? "on" : "")"
                                    @onclick="@(() => SendCommand(c, "macro", c.MacroRunning ? "false" : "true"))">
                                @(c.MacroRunning ? "■ Stop" : "▶ Start")
                            </button>
                            @foreach (var t in Toggles(c))
                            {
                                <button class="ac-pill @(t.On ? "on" : "")"
                                        @onclick="@(() => SendCommand(c, t.Action, t.On ? "false" : "true"))">@t.Label</button>
                            }
                        </div>
                        @if (c.NavProfiles is { Count: > 0 } || c.LootProfiles is { Count: > 0 } || c.MetaProfiles is { Count: > 0 })
                        {
                            <div class="ac-ctrl">
                                @if (c.NavProfiles is { Count: > 0 })
                                {
                                    <select class="ac-sel" title="nav profile" @onchange="@(e => CmdProfile(c, "navProfile", e))">
                                        @for (int i = 0; i < c.NavProfiles.Count; i++)
                                        { <option value="@i" selected="@(i == c.SelectedNavIdx)">@Trunc(c.NavProfiles[i])</option> }
                                    </select>
                                }
                                @if (c.LootProfiles is { Count: > 0 })
                                {
                                    <select class="ac-sel" title="loot profile" @onchange="@(e => CmdProfile(c, "lootProfile", e))">
                                        @for (int i = 0; i < c.LootProfiles.Count; i++)
                                        { <option value="@i" selected="@(i == c.SelectedLootIdx)">@Trunc(c.LootProfiles[i])</option> }
                                    </select>
                                }
                                @if (c.MetaProfiles is { Count: > 0 })
                                {
                                    <select class="ac-sel" title="meta profile" @onchange="@(e => CmdProfile(c, "metaProfile", e))">
                                        @for (int i = 0; i < c.MetaProfiles.Count; i++)
                                        { <option value="@i" selected="@(i == c.SelectedMetaIdx)">@Trunc(c.MetaProfiles[i])</option> }
                                    </select>
                                }
                            </div>
                        }
                        <div class="ac-ctrl">
                            <button class="ac-pill" @onclick="@(() => SendCommand(c, "clearBusy", "true"))">clear busy</button>
                            <button class="ac-pill" @onclick="@(() => SendCommand(c, "forceRebuff", "true"))">force rebuff</button>
                            <button class="ac-pill" @onclick="@(() => SendCommand(c, "cancelRebuff", "true"))">cancel</button>
                            <button class="ac-pill @(c.UiHidden ? "on" : "")" @onclick="@(() => SendCommand(c, "hideUi", c.UiHidden ? "false" : "true"))">@(c.UiHidden ? "Show UI" : "Hide UI")</button>
                            @if (_closePending.Contains(c.Pid))
                            {
                                <button class="ac-pill ac-danger" @onclick="@(() => ConfirmClose(c))">Confirm close?</button>
                            }
                            else
                            {
                                <button class="ac-pill" @onclick="@(() => ArmClose(c.Pid))">Close</button>
                            }
                        </div>
                        @if (_cmdMsg.TryGetValue(c.Pid, out var cm) && !string.IsNullOrEmpty(cm))
                        {
                            <div class="ac-cmd-msg">@cm</div>
                        }
                    }

                    <div class="ac-chat">
                        <button class="ac-gear-h" @onclick="@(() => ToggleChat(c.Pid))">
                            @(_showChat.Contains(c.Pid) ? "▾" : "▸") Chat@(c.RecentChat is { Count: > 0 } ? $" ({c.RecentChat.Count})" : "")
                        </button>
                        @if (_showChat.Contains(c.Pid))
                        {
                            <div class="ac-ctabs">
                                @foreach (var tab in ChatTabs)
                                {
                                    string t = tab; int pid = c.Pid;
                                    <button class="ac-pill ac-ctab @(ChatTabFor(pid) == t ? "on" : "")" @onclick="@(() => SetChatTab(pid, t))">@t</button>
                                }
                            </div>
                            <div class="ac-chat-log">
                                @{
                                    var curTab = ChatTabFor(c.Pid);
                                    var lines = (c.RecentChat ?? new()).Where(l => curTab == "All" || l.Route == curTab).ToList();
                                }
                                @if (lines.Count > 0)
                                {
                                    @for (int i = lines.Count - 1; i >= 0; i--)
                                    {
                                        <div class="ac-chat-line" style="color:@lines[i].Color">@lines[i].Text</div>
                                    }
                                }
                                else { <div class="ac-sub">@(c.RecentChat is { Count: > 0 } ? $"no {curTab} messages" : "no chat captured yet")</div> }
                            </div>
                            <div class="ac-chat-send">
                                <input class="ac-chat-input" placeholder="say, or /tell /f /command…"
                                       value="@GetDraft(c.Pid)"
                                       @oninput="@(e => _chatDraft[c.Pid] = e.Value?.ToString() ?? string.Empty)"
                                       @onkeydown="@(e => ChatKeyDown(e, c))" />
                                <button class="ac-pill" @onclick="@(() => SendChat(c))">Send</button>
                            </div>
                        }
                    </div>
                }

                <div class="ac-foot">
                    <span class="@(c.InWorld && c.Fps == 0 ? "ac-warn" : "")">@c.Fps fps</span>
                    <span class="@(c.MacroRunning && c.PluginTicksPerSec == 0 ? "ac-warn" : "")">@c.PluginTicksPerSec /s</span>
                    <span>up @Dur(c.UptimeSec)</span>
                    @if (c.AgeSec >= 12) { <span class="ac-warn">stale @c.AgeSec.ToString("F0")s</span> }
