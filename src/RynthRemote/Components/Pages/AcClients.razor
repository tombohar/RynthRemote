        // ReconcileHdOverlay rebuilds it with a fresh socket (its no-op short-circuit would otherwise skip it).
        if (_hdShownPid != null)
        {
            HdController.Hide();
            try { _ = JS.InvokeVoidAsync("rynthHd.stopTrack"); } catch { }
            _hdShownPid = null;
        }
        _ = InvokeAsync(StateHasChanged);
